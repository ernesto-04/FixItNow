@page "/available-tickets"

@inject HttpClient Http
@inject ProtectedLocalStorage LocalStorage
@inject NavigationManager NavigationManager
@inject AuthenticatedHttpService AuthenticatedHttpService
@inject TicketApiService TicketApiService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">

    <MudText Typo="Typo.h5" GutterBottom="true">
        Available Jobs
    </MudText>

    @if (tickets == null)
    {
        <MudGrid>
            @for (int i = 0; i < 6; i++)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudSkeleton Height="200px" />
                </MudItem>
            }
        </MudGrid>
    }
    else if (tickets.Count == 0)
    {
        <MudAlert Severity="Severity.Info">
            No available tickets right now.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var ticket in tickets)
            {
                <MudItem xs="12" sm="6" md="4">

                    <MudCard Class="rounded-xl hover-card"
                         Style="cursor:pointer;"
                         @onclick="@(() => GoToDetail(ticket.Id))">

                    <!-- IMAGE -->
                    @if (ticket.ImageUrls != null && ticket.ImageUrls.Any())
                    {
                        <MudImage Src="@ticket.ImageUrls.First()"
                                  Style="width:100%; aspect-ratio:16/9; object-fit:cover; border-radius:12px 12px 0 0;" />
                    }

                    <MudCardContent>

                        <!-- TITLE -->
                        <MudText Typo="Typo.h6">
                            @ticket.Title
                        </MudText>

                        <!-- DESCRIPTION -->
                        <MudText Typo="Typo.body2" Class="text-muted mb-2">
                            @Shorten(ticket.Description)
                        </MudText>

                        <!-- CATEGORY -->
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                            @ticket.Category
                        </MudChip>

                        <!-- STATUS -->
                        <MudChip T="string" Class="ml-2"
                                 Color="@GetStatusColor(ticket.Status.ToString())">
                            @ticket.Status
                        </MudChip>

                        <MudDivider Class="my-2" />

                        <!-- LOCATION -->
                        <MudText Typo="Typo.caption">
                            📍 @ticket.Location
                        </MudText>

                        <!-- CUSTOMER -->
                        <MudText Typo="Typo.caption">
                            👤 @ticket.CustomerName
                        </MudText>

                    </MudCardContent>

                </MudCard>
                </MudItem>
            }
        </MudGrid>
    }

</MudContainer>

@code {
    private List<AvailableTicketResponse> tickets = [];

    private bool isLoading = true;

    private bool isUpdating;

    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadTicketsAsync();

        StateHasChanged();
    }

    private async Task LoadTicketsAsync()
    {
        try
        {
            isLoading = true;

            tickets =
                await TicketApiService.GetAvailableTicketsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateStatus(
        int ticketId,
        TicketStatus newStatus)
    {
        try
        {
            isUpdating = true;

            var client =
                await AuthenticatedHttpService.GetClientAsync();

            if (client is null)
            {
                errorMessage = "Authentication failed.";
                return;
            }

            var response = await client.PutAsync(
                $"api/tickets/{ticketId}/status?status={newStatus}",
                null);

            if (!response.IsSuccessStatusCode)
            {
                errorMessage =
                    $"Failed to update status ({(int)response.StatusCode})";

                return;
            }

            await LoadTicketsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isUpdating = false;
        }
    }

    private static string Shorten(string? text) =>
        string.IsNullOrWhiteSpace(text)
            ? string.Empty
            : text.Length <= 80
                ? text
                : $"{text[..80]}...";

    private static Color GetStatusColor(string? status) =>
        status switch
        {
            "Unassigned" => Color.Default,
            "Assigned" => Color.Info,
            "Started" => Color.Warning,
            "InProgress" => Color.Warning,
            "Completed" => Color.Success,
            _ => Color.Default
        };

    private void GoToDetail(int ticketId) =>
        NavigationManager.NavigateTo(
            $"/available-tickets/{ticketId}");
}