@page "/register"
@layout LoginLayout

<PageTitle>Register</PageTitle>

<MudForm Model="@registerRequest">
    <MudCard Elevation="3">
        <MudCardHeader>
            <CardHeaderContent>
                <MudGrid>
                    <MudItem xs="12" Class="d-flex justify-center align-center">
                        <div style="width:40px;height:40px;display:flex;align-items:center;justify-content:center;background:#46A583;color:white;border-radius:8px" class="mr-2">
                            <MudIcon Icon="@Icons.Material.Rounded.Build" Size="Size.Medium" />
                        </div>
                        <MudText Typo="Typo.h6">FixItNow</MudText>
                    </MudItem>

                    <MudItem xs="12" Class="d-flex">
                        <MudText Typo="Typo.caption" Class="mx-auto">
                            Create your FixItNow account
                        </MudText>
                    </MudItem>
                </MudGrid>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            <FixItNow.Web.Components.Custom.Progress.CircularLoader Visible="@_isLoading" />

            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="registerRequest.FullName"
                                  Label="Full Name"
                                  Required="true"
                                  RequiredError="Name is required" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="registerRequest.Username"
                                  Label="Username"
                                  Required="true"
                                  RequiredError="Username is required" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="registerRequest.Email"
                                  Label="Email"
                                  Required="true"
                                  RequiredError="Email is required" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="registerRequest.Password"
                                  Label="Password"
                                  InputType="@_passwordInput"
                                  Required="true"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@_passwordIcon"
                                  OnAdornmentClick="OnShowHidePasswordClick"
                                  RequiredError="Password is required" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="confirmPassword"
                                  Label="Confirm Password"
                                  InputType="@_passwordInput"
                                  Required="true"
                                  RequiredError="Confirm password is required" />
                </MudItem>
            </MudGrid>
        </MudCardContent>

        <MudCardActions>
            <MudGrid>
                <MudItem xs="12" Class="d-flex">
                    <MudButton StartIcon="@Icons.Material.Filled.PersonAdd"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               OnClick="Regis">

                        @if (_isLoading)
                        {
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                        }
                        else
                        {
                            <p>Register</p>
                        }
                    </MudButton>
                </MudItem>
                <MudItem xs="12" Class="d-flex justify-center mt-4">
                    <MudText Typo="Typo.caption">
                        Already have account?
                        <MudLink Href="/">Login</MudLink>
                    </MudText>
                </MudItem>
            </MudGrid>
        </MudCardActions>
    </MudCard>
</MudForm>

@if (_pageError != "")
{
    <div class="alert error mt-8 mb-0" style="color: red; font-weight: bold;">
        @_pageError
    </div>
}

@code {
    @inject IAuthenticationService _authService
    @inject NavigationManager NavigationManager

    RegisterRequest registerRequest = new();
    string confirmPassword = string.Empty;

    bool _isLoading = false;
    string _pageError = string.Empty;

    bool _isShowPassword = false;
    InputType _passwordInput = InputType.Password;
    string _passwordIcon = Icons.Material.Filled.VisibilityOff;

    void OnShowHidePasswordClick()
    {
        _isShowPassword = !_isShowPassword;

        _passwordInput = _isShowPassword ? InputType.Text : InputType.Password;
        _passwordIcon = _isShowPassword
            ? Icons.Material.Filled.Visibility
            : Icons.Material.Filled.VisibilityOff;
    }

    async Task Regis()
    {
        try
        {
            _pageError = string.Empty;

            if (registerRequest.Password != confirmPassword)
            {
                _pageError = "Passwords do not match";
                return;
            }

            _isLoading = true;
            StateHasChanged();

            await _authService.Register(registerRequest);

            NavigationManager.NavigateTo("/", true);
        }
        catch (Exception e)
        {
            _pageError = e.Message;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
}