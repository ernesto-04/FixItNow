@page "/admin/technicians"

@using FixItNow.Domain.Models.BookingRequest.DTOs.Technicians
@using Microsoft.AspNetCore.Authorization

@inject AdminApiService AdminApiService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthenticationStateProvider

<div>
    @if (_isLoading)
    {
        <div style="display:flex; align-items:center; justify-content:center; min-height:60vh;">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else
    {
        <!-- PAGE HEADER -->
        <div style="padding: 40px 48px 0;">
            <h1 style="font-size:32px; font-weight:800; color:var(--text);
                           letter-spacing:-0.8px; margin-bottom:6px;">
                Technician Approvals
            </h1>
            <p style="font-size:15px; color:var(--muted); margin-bottom:32px;">
                Review and approve technician applications
            </p>

            <!-- TABS -->
            <div style="display:flex; gap:0; border-bottom:1px solid var(--border); margin-bottom:0;">
                @foreach (var tab in new[] { "Pending", "Rejected" })
                {
                    <div @onclick="@(() => _activeTab = tab)"
                         style="padding:12px 24px; cursor:pointer; font-size:14px;
                                        font-weight:@(_activeTab == tab ? "700" : "500");
                                        color:@(_activeTab == tab ? "var(--text)" : "var(--muted)");
                                        border-bottom:2px solid @(_activeTab == tab ? "var(--text)" : "transparent");
                                        transition:all .15s ease;">
                        @tab
                        <span style="margin-left:6px; background:@(_activeTab == tab ? "var(--text)" : "#eee");
                                             color:@(_activeTab == tab ? "#fff" : "var(--muted)");
                                             border-radius:99px; padding:2px 8px; font-size:12px;">
                            @(_activeTab == "Pending" ? _pending.Count : _rejected.Count)
                        </span>
                    </div>
                }
            </div>
        </div>

        <!-- LIST -->
        <div style="padding: 32px 48px;">
            @{
                var list = _activeTab == "Pending" ? _pending : _rejected;
            }

            @if (list.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-state-icon">@(_activeTab == "Pending" ? "✅" : "🚫")</div>
                    <div class="empty-state-title">No @_activeTab.ToLower() applications</div>
                    <div class="empty-state-text">
                        @(_activeTab == "Pending"
                                        ? "All caught up — no applications waiting for review."
                                        : "No technicians have been rejected yet.")
            </div>
        </div>
                }
            else
            {
                <div style="display:flex; flex-direction:column; gap:16px;">
                    @foreach (var tech in list)
                    {
                        <div style="background:#fff; border:1px solid var(--border);
                                                border-radius:12px; padding:24px;
                                                display:flex; gap:20px; align-items:flex-start;">

                            <!-- AVATAR -->
                            <div style="width:56px; height:56px; border-radius:50%;
                                                    background:var(--green); color:#fff;
                                                    display:flex; align-items:center; justify-content:center;
                                                    font-size:22px; font-weight:700; flex-shrink:0;
                                                    overflow:hidden;">
                                @if (!string.IsNullOrWhiteSpace(tech.ProfileImageUrl)
                                                    && Uri.IsWellFormedUriString(tech.ProfileImageUrl, UriKind.Absolute))
                                {
                                    <img src="@tech.ProfileImageUrl" alt="@tech.FullName"
                                         style="width:100%; height:100%; object-fit:cover;" />
                                }
                                else
                                {
                                    @tech.FullName.FirstOrDefault()
                                }
                            </div>

                            <!-- INFO -->
                            <div style="flex:1; min-width:0;">
                                <div style="display:flex; align-items:center; gap:10px; margin-bottom:4px;">
                                    <span style="font-size:17px; font-weight:700; color:var(--text);">
                                        @tech.FullName
                                    </span>
                                    <span style="font-size:12px; color:var(--muted);">
                                        📍 @tech.Location
                                    </span>
                                </div>

                                <div style="font-size:13px; color:var(--muted); margin-bottom:8px;">
                                    @tech.YearsExperience yrs experience &nbsp;·&nbsp; @tech.Skills
                                </div>

                                @if (!string.IsNullOrWhiteSpace(tech.Bio))
                                {
                                    <div style="font-size:14px; color:var(--text); margin-bottom:8px;">
                                        @TextHelper.Shorten(tech.Bio, 120)
                                    </div>
                                }

                                @if (_activeTab == "Rejected" && !string.IsNullOrWhiteSpace(tech.RejectionReason))
                                {
                                    <div style="font-size:13px; color:#c0392b; background:#fdf0ee;
                                                                border-radius:6px; padding:8px 12px; margin-top:4px;">
                                        ❌ Rejection reason: @tech.RejectionReason
                                    </div>
                                }
                            </div>

                            <!-- ACTIONS -->
                            <div style="display:flex; flex-direction:column; gap:8px; flex-shrink:0;">
                                @if (_activeTab == "Pending")
                                {
                                    <button @onclick="@(() => ApproveAsync(tech.UserId))"
                                            disabled="@_isActing"
                                            style="background:var(--green); color:#fff; border:none;
                                                                   border-radius:8px; padding:10px 20px;
                                                                   font-size:14px; font-weight:600;
                                                                   cursor:pointer; font-family:inherit;
                                                                   opacity:@(_isActing ? "0.6" : "1");">
                                        ✓ Approve
                                    </button>
                                    <button @onclick="@(() => OpenRejectDialog(tech))"
                                            disabled="@_isActing"
                                            style="background:#fff; color:#c0392b;
                                                                   border:1px solid #c0392b;
                                                                   border-radius:8px; padding:10px 20px;
                                                                   font-size:14px; font-weight:600;
                                                                   cursor:pointer; font-family:inherit;
                                                                   opacity:@(_isActing ? "0.6" : "1");">
                                        ✕ Reject
                                    </button>
                                }
                            </div>

                        </div>
                    }
                </div>
            }
        </div>

        <!-- REJECT DIALOG -->
        @if (_rejectTarget is not null)
        {
            <div style="position:fixed; inset:0; background:rgba(0,0,0,0.4);
                                z-index:1000; display:flex; align-items:center; justify-content:center;">
                <div style="background:#fff; border-radius:16px; padding:32px;
                                    width:100%; max-width:480px; box-shadow:0 8px 32px rgba(0,0,0,0.12);">

                    <h2 style="font-size:20px; font-weight:800; color:var(--text);
                                       margin-bottom:6px;">
                        Reject Application
                    </h2>
                    <p style="font-size:14px; color:var(--muted); margin-bottom:20px;">
                        Provide a reason for rejecting <strong>@_rejectTarget.FullName</strong>.
                        They will be able to see this.
                    </p>

                    <textarea @bind="_rejectReason"
                              placeholder="e.g. Incomplete profile, missing skills info..."
                              rows="4"
                              style="width:100%; border:1px solid var(--border);
                                             border-radius:8px; padding:12px;
                                             font-size:14px; font-family:inherit;
                                             color:var(--text); resize:vertical;
                                             outline:none; box-sizing:border-box;" />

                    @if (!string.IsNullOrWhiteSpace(_rejectError))
                    {
                        <p style="font-size:13px; color:#c0392b; margin-top:8px;">
                            @_rejectError
                        </p>
                    }

                    <div style="display:flex; gap:12px; margin-top:20px; justify-content:flex-end;">
                        <button @onclick="CloseRejectDialog"
                                style="background:#f5f5f5; border:none; border-radius:8px;
                                               padding:10px 20px; font-size:14px; font-weight:600;
                                               cursor:pointer; font-family:inherit; color:var(--text);">
                            Cancel
                        </button>
                        <button @onclick="ConfirmRejectAsync"
                                disabled="@_isActing"
                                style="background:#c0392b; color:#fff; border:none;
                                               border-radius:8px; padding:10px 20px;
                                               font-size:14px; font-weight:600;
                                               cursor:pointer; font-family:inherit;
                                               opacity:@(_isActing ? "0.6" : "1");">
                            Confirm Reject
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private bool _isLoading = true;
    private bool _isActing = false;
    private string _activeTab = "Pending";
    private List<TechnicianProfileDto> _pending = [];
    private List<TechnicianProfileDto> _rejected = [];

    private TechnicianProfileDto? _rejectTarget;
    private string _rejectReason = string.Empty;
    private string _rejectError = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var isAdmin = authState.User.FindFirstValue("IsAdmin") == "True";
        if (!isAdmin)
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var results = await Task.WhenAll(
                AdminApiService.GetPendingTechniciansAsync(),
                AdminApiService.GetRejectedTechniciansAsync());
            _pending = results[0];
            _rejected = results[1];
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ApproveAsync(int userId)
    {
        _isActing = true;
        try
        {
            var success = await AdminApiService.ApproveTechnicianAsync(userId);
            if (success)
            {
                Snackbar.Add("Technician approved.", Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add("Failed to approve technician.", Severity.Error);
            }
        }
        finally
        {
            _isActing = false;
            StateHasChanged();
        }
    }

    private void OpenRejectDialog(TechnicianProfileDto tech)
    {
        _rejectTarget = tech;
        _rejectReason = string.Empty;
        _rejectError = string.Empty;
        StateHasChanged();
    }

    private void CloseRejectDialog()
    {
        _rejectTarget = null;
        _rejectReason = string.Empty;
        _rejectError = string.Empty;
        StateHasChanged();
    }

    private async Task ConfirmRejectAsync()
    {
        if (string.IsNullOrWhiteSpace(_rejectReason))
        {
            _rejectError = "Please provide a rejection reason.";
            return;
        }
        _isActing = true;
        try
        {
            var success = await AdminApiService.RejectTechnicianAsync(_rejectTarget!.UserId, _rejectReason);
            if (success)
            {
                Snackbar.Add("Technician rejected.", Severity.Success);
                CloseRejectDialog();
                await LoadAsync();
            }
            else
            {
                _rejectError = "Failed to reject. Please try again.";
            }
        }
        finally
        {
            _isActing = false;
            StateHasChanged();
        }
    }
}