@page "/available-tickets"


<h3>Tickets</h3>

@if (tickets == null)
{
	<p>Loading...</p>
}
else if (tickets.Count == 0)
{
	<p>No tickets found.</p>
}
else
{
	<ul>
		@foreach (var ticket in tickets)
		{
			<li style="margin-bottom:20px; border:1px solid #ccc; padding:10px;">
				<h4>@ticket.Title</h4>
				<p>@ticket.Description</p>

				<p><strong>Category:</strong> @ticket.Category</p>
				<p><strong>Location:</strong> @ticket.Location</p>
				
				<p>
					<strong>Technician:</strong>
					@(ticket.TechnicianName ?? "Not assigned")
				</p>
				
				<p>
					<strong>Status: @ticket.Status</strong>
				</p>
				<p><strong>ID:</strong> @ticket.Id</p>

				@if(ticket.Status == TicketStatus.Unassigned)
				{
					<MudButton Variant="Variant.Filled" @onclick="() => AcceptTicket(ticket.Id)">
						Accept Ticket
					</MudButton>
				}
			</li>
		}
	</ul>

	<MudButton OnClick="HandleTechnicianAction">
		@(_isTechnician ? "Go to Technician Dashboard" : "Become a Technician")
	</MudButton>
}

@code {
	@inject HttpClient Http
	@inject ProtectedLocalStorage LocalStorage
	@inject NavigationManager NavigationManager
	@inject IDialogService DialogService

	private bool _isTechnician = false;

	private List<Ticket> tickets;

	protected override async Task OnInitializedAsync()
	{
		await LoadTickets();
		_isTechnician = await IsTechnician();
	}

	async Task HandleTechnicianAction()
	{
		if (_isTechnician)
		{
			// ✅ Already technician → go dashboard
			NavigationManager.NavigateTo("/technician-dashboard");
		}
		else
		{
			// ❌ Not technician → open dialog
			await OpenTechnicianDialog();
		}
	}

	async Task OpenTechnicianDialog()
	{
		var dialog = await DialogService.ShowAsync<BecomeTechnicianDialog>("Become Technician");
		var result = await dialog.Result;
		if (!result.Canceled)
		{
			// 🔥 Refresh UI (user is now technician)
			NavigationManager.NavigateTo("/technician/jobs", true);
		}
	}

	private async Task<bool> IsTechnician()
	{
		var token = await GetToken();
		if (token == null) return false;

		var request = new HttpRequestMessage(
			HttpMethod.Get,
			"https://localhost:7008/api/users/is-technician"
		);

		request.Headers.Authorization =
			new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

		var response = await Http.SendAsync(request);

		if (response.IsSuccessStatusCode)
		{
			return await response.Content.ReadFromJsonAsync<bool>();
		}

		return false;
	}

	private async Task<string> GetToken()
	{
		var token = await LocalStorage.GetAsync<string>("token");
		if (!token.Success || string.IsNullOrEmpty(token.Value)) return null;

		return token.Value;

	}

	private async Task LoadTickets()
	{
		var token = await GetToken();
		if (token == null) return;
		var request = new HttpRequestMessage(HttpMethod.Get, "https://localhost:7008/api/tickets/available-tickets");
		request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
		var response = await Http.SendAsync(request);
		if (response.IsSuccessStatusCode)
		{
			tickets = await response.Content.ReadFromJsonAsync<List<Ticket>>();
		}
	}

	private async Task AcceptTicket(int ticketId)
	{
		var token = await GetToken();
		if (token == null) return;
		var request = new HttpRequestMessage(HttpMethod.Post, $"https://localhost:7008/api/tickets/{ticketId}/accept");
		request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

		var response = await Http.SendAsync(request);

		if (response.IsSuccessStatusCode)
		{
			await LoadTickets(); // refresh UI
		}
	}

	private async Task UpdateStatus(int ticketId, TicketStatus newStatus)
	{

		var token = await GetToken();
		if (token == null) return;

		var statusString = newStatus.ToString();
		var request = new HttpRequestMessage(HttpMethod.Put,
			$"https://localhost:7008/api/tickets/{ticketId}/status?status={statusString}");
		request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
		await Http.SendAsync(request);

		await LoadTickets();
	}

	public class Ticket
	{
		public int Id { get; set; }
		public string Title { get; set; }
		public string TechnicianName { get; set; }
		public TicketStatus Status { get; set; }
		public string Description { get; set; }
		public string Category { get; set; }
		public string Location { get; set; }
	}
	public enum TicketStatus
	{
		Unassigned,
		Assigned,
		InProgress,
		Completed
	}
}
