@page "/customer-tickets"

@inject HttpClient Http
@inject ProtectedLocalStorage LocalStorage
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject AuthenticatedHttpService AuthenticatedHttpService
@inject TicketApiService TicketApiService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">

    <MudText Typo="Typo.h5" GutterBottom="true">
        My Service Requests
    </MudText>

    @if (tickets == null)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (tickets.Count == 0)
    {
        <MudText>@errorMessage</MudText>

        <MudText>Ticket count: @tickets.Count</MudText>
        <MudAlert Severity="Severity.Info">
            You haven’t created any tickets yet.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var ticket in tickets)
            {
                <MudItem xs="12" sm="6" md="4">

                    <MudCard Class="rounded-xl hover-card"
                             Style="cursor:pointer;"
                             @onclick="@(() => ViewDetails(ticket.Id))">

                        <!-- IMAGE -->
                        @if (ticket.ImageUrls != null && ticket.ImageUrls.Any())
                        {
                            <MudImage Src="@ticket.ImageUrls.First()"
                                      Style="width:100%; aspect-ratio:16/9; object-fit:cover; border-radius:12px 12px 0 0;" />
                        }

                        <MudCardContent>

                            <!-- TITLE -->
                            <MudText Typo="Typo.h6">
                                @ticket.Title
                            </MudText>

                            <!-- DESCRIPTION -->
                            <MudText Typo="Typo.body2" Class="mb-2 text-muted">
                                @Shorten(ticket.Description)
                            </MudText>

                            <!-- CATEGORY -->
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                                @ticket.Category
                            </MudChip>

                            <!-- STATUS -->
                            <MudChip T="string" Class="ml-2"
                                     Color="@GetStatusColor(ticket.Status)">
                                @ticket.Status
                            </MudChip>

                            <MudDivider Class="my-2" />

                            <!-- LOCATION -->
                            <MudText Typo="Typo.caption">
                                📍 @ticket.Location
                            </MudText>

                            <br />

                            <!-- TECHNICIAN -->
                            <MudText Typo="Typo.caption">
                                👨‍🔧 @(ticket.TechnicianName ?? "Not assigned")
                            </MudText>

                        </MudCardContent>

                        <MudCardActions>

                            @if ((ticket.Status == TicketStatus.Assigned ||
                                                ticket.Status == TicketStatus.InProgress)
                                                && ticket.AssignedTechnicianId > 0)
                                                {
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Success"
                                           @onclick="@(() => OpenChat(ticket.Id))">
                                    Chat
                                </MudButton>
                            }

                        </MudCardActions>

                    </MudCard>

                </MudItem>
            }
        </MudGrid>
    }

</MudContainer>

@code {

    private List<CustomerTicketResponse> tickets = [];

    private bool isLoading = true;

    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadTicketsAsync();

        StateHasChanged();
    }

    private async Task LoadTicketsAsync()
    {
        try
        {
            isLoading = true;

            tickets =
                await TicketApiService.GetCustomerTicketsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ViewDetails(int ticketId) =>
        NavigationManager.NavigateTo(
            $"/ticket/{ticketId}");

    private void OpenChat(int ticketId) =>
        NavigationManager.NavigateTo(
            $"/chat/{ticketId}");

    private static string Shorten(string? text) =>
        string.IsNullOrWhiteSpace(text)
            ? string.Empty
            : text.Length <= 80
                ? text
                : $"{text[..80]}...";

    private static Color GetStatusColor(
        TicketStatus status) =>
        status switch
        {
            TicketStatus.Unassigned => Color.Default,
            TicketStatus.Assigned => Color.Info,
            TicketStatus.InProgress => Color.Warning,
            TicketStatus.Completed => Color.Success,
            _ => Color.Default
        };
}