@page "/technician-tickets"

@inject HttpClient Http
@inject ProtectedLocalStorage LocalStorage
@inject NavigationManager NavigationManager
@inject TicketApiService TicketApiService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">

    <MudText Typo="Typo.h5" GutterBottom="true">
        My Jobs
    </MudText>

    @if (tickets == null)
    {
        <MudGrid>
            @for (int i = 0; i < 4; i++)
            {
                <MudItem xs="12" sm="6">
                    <MudSkeleton Height="180px" />
                </MudItem>
            }
        </MudGrid>
    }
    else if (tickets.Count == 0)
    {
        <MudAlert Severity="Severity.Info">
            No assigned jobs yet.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var ticket in tickets)
            {
                <MudItem xs="12" sm="6" md="4">

                    <MudCard Class="rounded-xl hover-card"
                             Style="cursor:pointer;"
                             @onclick="@(() => GoToDetail(ticket.Id))">

                        <!-- IMAGE -->
                        @if (ticket.ImageUrls != null && ticket.ImageUrls.Any())
                        {
                            <MudImage Src="@ticket.ImageUrls.First()"
                                      Style="width:100%; aspect-ratio:16/9; object-fit:cover; border-radius:12px 12px 0 0;" />
                        }

                        <MudCardContent>

                            <!-- TITLE -->
                            <MudText Typo="Typo.h6">
                                @ticket.Title
                            </MudText>

                            <!-- DESCRIPTION -->
                            <MudText Typo="Typo.body2" Class="text-muted mb-2">
                                @Shorten(ticket.Description)
                            </MudText>

                            <!-- CATEGORY -->
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                                @ticket.Category
                            </MudChip>

                            <!-- STATUS -->
                            <MudChip T="TechnicianTicketResponse" Class="ml-2"
                                     Color="@GetStatusColor(ticket.Status)">
                                @ticket.Status
                            </MudChip>

                            <MudDivider Class="my-2" />

                            <!-- CUSTOMER -->
                            <MudText Typo="Typo.caption">
                                Customer: @ticket.CustomerName
                            </MudText>

                            <br />

                            <!-- LOCATION -->
                            <MudText Typo="Typo.caption">
                                Location: @ticket.Location
                            </MudText>

                        </MudCardContent>

                        <MudCardActions Class="d-flex flex-column gap-2">

                            @if (ticket.Status == TicketStatus.Assigned)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           FullWidth="true"
                                           @onclick="() => UpdateStatus(ticket.Id, TicketStatus.InProgress)">
                                    Start Job
                                </MudButton>
                            }
                            else if (ticket.Status == TicketStatus.InProgress)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Success"
                                           FullWidth="true"
                                           @onclick="() => UpdateStatus(ticket.Id, TicketStatus.Completed)">
                                    Complete Job
                                </MudButton>

                                <!-- CHAT BUTTON -->
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Info"
                                           FullWidth="true"
                                           @onclick="@(() => OpenChat(ticket.Id))">
                                    Chat Customer
                                </MudButton>
                            }
                            else if (ticket.Status == TicketStatus.Completed)
                            {
                                <MudChip T="string" Color="Color.Success" Variant="Variant.Filled">
                                    Completed
                                </MudChip>
                            }

                        </MudCardActions>

                    </MudCard>

                </MudItem>
            }
        </MudGrid>
    }

</MudContainer>

@code {

    private List<TechnicianTicketResponse> tickets = [];

    private bool isLoading = true;

    private bool isUpdating;

    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadTicketsAsync();

        StateHasChanged();
    }

    private async Task LoadTicketsAsync()
    {
        try
        {
            isLoading = true;

            tickets =
                await TicketApiService.GetTechnicianTicketsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateStatus(
        int ticketId,
        TicketStatus status)
    {
        try
        {
            isUpdating = true;

            var success =
                await TicketApiService.UpdateTicketStatusAsync(
                    ticketId,
                    status);

            if (!success)
            {
                errorMessage =
                    "Failed to update ticket status.";

                return;
            }

            await LoadTicketsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isUpdating = false;
        }
    }

    private void GoToDetail(int ticketId) =>
        NavigationManager.NavigateTo(
            $"/technician-tickets/{ticketId}");

    private void OpenChat(int ticketId) =>
        NavigationManager.NavigateTo(
            $"/chat/{ticketId}");

    private static string Shorten(string? text) =>
        string.IsNullOrWhiteSpace(text)
            ? string.Empty
            : text.Length <= 80
                ? text
                : $"{text[..80]}...";

    private static Color GetStatusColor(
        TicketStatus status) =>
        status switch
        {
            TicketStatus.Assigned => Color.Info,
            TicketStatus.InProgress => Color.Warning,
            TicketStatus.Completed => Color.Success,
            _ => Color.Default
        };
}