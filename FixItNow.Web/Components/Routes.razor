<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="@GetLayout()" @key="currentLayout">
                <NotAuthorized>
                    <h1>Not authorized</h1>
                </NotAuthorized>
                <Authorizing>
                    <h1>Authorizing..</h1>
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(LoginLayout)">
                <p>Sorry, there's nothing at this address.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    @inject ProtectedLocalStorage LocalStorage

    private Type currentLayout = typeof(CustomerLayout);
    private bool isLoaded = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var mode = await LocalStorage.GetAsync<string>("mode");

            if (mode.Success && mode.Value == "technician")
            {
                currentLayout = typeof(TechnicianLayout);
            }
            else
            {
                currentLayout = typeof(CustomerLayout);
            }

            isLoaded = true;
            StateHasChanged(); // 🔥 force re-render
        }
    }

    private Type GetLayout()
    {
        return currentLayout;
    }
}