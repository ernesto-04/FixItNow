@page "/available-tickets"

@using MudBlazor
@using FixItNow.Domain.Models.Tickets

@inject HttpClient Http
@inject ProtectedLocalStorage LocalStorage
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">

    <MudText Typo="Typo.h5" GutterBottom="true">
        Available Jobs
    </MudText>

    @if (tickets == null)
    {
        <MudGrid>
            @for (int i = 0; i < 6; i++)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudSkeleton Height="200px" />
                </MudItem>
            }
        </MudGrid>
    }
    else if (tickets.Count == 0)
    {
        <MudAlert Severity="Severity.Info">
            No available tickets right now.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var ticket in tickets)
            {
                <MudItem xs="12" sm="6" md="4">

                    <MudCard Class="rounded-xl hover-card"
                         Style="cursor:pointer;"
                         @onclick="@(() => GoToDetail(ticket.Id))">

                    <!-- IMAGE -->
                    @if (ticket.ImageUrls != null && ticket.ImageUrls.Any())
                    {
                        <MudImage Src="@ticket.ImageUrls.First()"
                                  Style="width:100%; aspect-ratio:16/9; object-fit:cover; border-radius:12px 12px 0 0;" />
                    }

                    <MudCardContent>

                        <!-- TITLE -->
                        <MudText Typo="Typo.h6">
                            @ticket.Title
                        </MudText>

                        <!-- DESCRIPTION -->
                        <MudText Typo="Typo.body2" Class="text-muted mb-2">
                            @Shorten(ticket.Description)
                        </MudText>

                        <!-- CATEGORY -->
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                            @ticket.Category
                        </MudChip>

                        <!-- STATUS -->
                        <MudChip T="string" Class="ml-2"
                                 Color="@GetStatusColor(ticket.Status.ToString())">
                            @ticket.Status
                        </MudChip>

                        <MudDivider Class="my-2" />

                        <!-- LOCATION -->
                        <MudText Typo="Typo.caption">
                            📍 @ticket.Location
                        </MudText>

                        <!-- CUSTOMER -->
                        <MudText Typo="Typo.caption">
                            👤 @ticket.CustomerName
                        </MudText>

                    </MudCardContent>

                </MudCard>
                </MudItem>
            }
        </MudGrid>
    }

</MudContainer>

@code {
    private List<AvailableTicketResponse> tickets;

    protected override async Task OnInitializedAsync()
    {
        await LoadTickets();
    }

    private async Task<string> GetToken()
    {
        var token = await LocalStorage.GetAsync<string>("token");
        return token.Success ? token.Value : null;
    }

    private async Task LoadTickets()
    {
        var token = await GetToken();
        if (token == null) return;

        var request = new HttpRequestMessage(HttpMethod.Get,
            "https://localhost:7008/api/tickets/available-tickets");

        request.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var response = await Http.SendAsync(request);

        if (response.IsSuccessStatusCode)
        {
            tickets = await response.Content
                .ReadFromJsonAsync<List<AvailableTicketResponse>>();
        }
    }

    private async Task UpdateStatus(int ticketId, TicketStatus newStatus)
    {
        var token = await GetToken();
        if (token == null) return;

        var request = new HttpRequestMessage(HttpMethod.Put,
            $"https://localhost:7008/api/tickets/{ticketId}/status?status={newStatus}");

        request.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        await Http.SendAsync(request);

        await LoadTickets();
    }

    private string Shorten(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        return text.Length > 80 ? text.Substring(0, 80) + "..." : text;
    }

    private Color GetStatusColor(string status)
    {
        return status switch
        {
            "Unassigned" => Color.Default,
            "Assigned" => Color.Info,
            "Started" => Color.Warning,
            "InProgress" => Color.Warning,
            "Completed" => Color.Success,
            _ => Color.Default
        };
    }

    private void GoToDetail(int id)
    {
        NavigationManager.NavigateTo($"/available-tickets/{id}");
    }
}