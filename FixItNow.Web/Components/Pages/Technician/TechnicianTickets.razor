@page "/technician-tickets"
@layout TechnicianLayout

@using MudBlazor
@using FixItNow.Domain.Models.Tickets

@inject HttpClient Http
@inject ProtectedLocalStorage LocalStorage

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">

    <MudText Typo="Typo.h5" GutterBottom="true">
        My Jobs
    </MudText>

    @if (tickets == null)
    {
        <MudGrid>
            @for (int i = 0; i < 4; i++)
            {
                <MudItem xs="12" sm="6">
                    <MudSkeleton Height="180px" />
                </MudItem>
            }
        </MudGrid>
    }
    else if (tickets.Count == 0)
    {
        <MudAlert Severity="Severity.Info">
            No assigned jobs yet.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var ticket in tickets)
            {
                <MudItem xs="12" sm="6" md="4">

                    <MudCard Class="rounded-xl">

                        <!-- IMAGE -->
                        @if (ticket.Images != null && ticket.Images.Any())
                        {
                            <MudCardMedia Image="@($"https://localhost:7008/uploads/{ticket.Images.First()}")"
                                          Height="160" />
                        }

                        <MudCardContent>

                            <!-- TITLE -->
                            <MudText Typo="Typo.h6">
                                @ticket.Title
                            </MudText>

                            <!-- DESCRIPTION -->
                            <MudText Typo="Typo.body2" Class="text-muted mb-2">
                                @Shorten(ticket.Description)
                            </MudText>

                            <!-- CATEGORY -->
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                                @ticket.Category
                            </MudChip>

                            <!-- STATUS -->
                            <MudChip T="TechnicianTicketResponse" Class="ml-2"
                                     Color="@GetStatusColor(ticket.Status)">
                                @ticket.Status
                            </MudChip>

                            <MudDivider Class="my-2" />

                            <!-- CUSTOMER -->
                            <MudText Typo="Typo.caption">
                                Customer: @ticket.CustomerName
                            </MudText>

                            <br />

                            <!-- LOCATION -->
                            <MudText Typo="Typo.caption">
                                Location: @ticket.Location
                            </MudText>

                        </MudCardContent>

                        <MudCardActions Class="d-flex flex-column gap-2">

                            @if (ticket.Status == TicketStatus.Assigned)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           FullWidth="true"
                                           OnClick="() => UpdateStatus(ticket.Id, TicketStatus.InProgress)">
                                    Start Job
                                </MudButton>
                            }
                            else if (ticket.Status == TicketStatus.InProgress)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Success"
                                           FullWidth="true"
                                           OnClick="() => UpdateStatus(ticket.Id, TicketStatus.Completed)">
                                    Complete Job
                                </MudButton>
                            }
                            else if (ticket.Status == TicketStatus.Completed)
                            {
                                <MudChip T="string" Color="Color.Success" Variant="Variant.Filled">
                                    Completed
                                </MudChip>
                            }

                        </MudCardActions>

                    </MudCard>

                </MudItem>
            }
        </MudGrid>
    }

</MudContainer>

@code {
    private List<TechnicianTicketResponse> tickets;

    protected override async Task OnInitializedAsync()
    {
        await LoadTickets();
    }

    private async Task<string> GetToken()
    {
        var token = await LocalStorage.GetAsync<string>("token");
        return token.Success ? token.Value : null;
    }

    private async Task LoadTickets()
    {
        var token = await GetToken();
        if (token == null) return;

        var request = new HttpRequestMessage(HttpMethod.Get,
            "https://localhost:7008/api/tickets/technician-tickets");

        request.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var response = await Http.SendAsync(request);

        if (response.IsSuccessStatusCode)
        {
            tickets = await response.Content
                .ReadFromJsonAsync<List<TechnicianTicketResponse>>();
        }
    }

    private async Task UpdateStatus(int ticketId, TicketStatus status)
    {
        var token = await GetToken();
        if (token == null) return;

        var request = new HttpRequestMessage(HttpMethod.Put,
            $"https://localhost:7008/api/tickets/{ticketId}/status?status={status}");

        request.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var response = await Http.SendAsync(request);

        if (response.IsSuccessStatusCode)
        {
            await LoadTickets();
        }
    }

    private string Shorten(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        return text.Length > 80 ? text.Substring(0, 80) + "..." : text;
    }

    private Color GetStatusColor(TicketStatus status)
    {
        return status switch
        {
            TicketStatus.Assigned => Color.Info,
            TicketStatus.InProgress => Color.Warning,
            TicketStatus.Completed => Color.Success,
            _ => Color.Default
        };
    }
}