@page "/technicians"
@using FixItNow.Domain.Models.BookingRequest.DTOs.Technicians
@using FixItNow.Web.ApiServices
@using FixItNow.Web.Components.Pages.Technician.Cards

@inject TechnicianApiService TechnicianApiService
@inject NavigationManager NavigationManager

<div>

    @if (_isLoading)
    {
        <div style="display:flex; align-items:center; justify-content:center; min-height:60vh;">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else
    {
        <!-- PAGE HEADER -->
        <div style="padding: 40px 48px 0;">
            <h1 style="font-size:32px; font-weight:800; color:var(--text);
                   letter-spacing:-0.8px; margin-bottom:6px;">
                Browse Technicians
            </h1>
            <p style="font-size:15px; color:var(--muted); margin-bottom:32px;">
                Find and book skilled professionals near you
            </p>
            <div style="display:flex; gap:4px; overflow-x:auto;
                    padding-bottom:0; scrollbar-width:none;
                    border-bottom:1px solid var(--border);">
                @foreach (var cat in _categories)
                {
                    <div @onclick="@(() => SelectCategory(cat.Label))"
                         style="display:flex; flex-direction:column; align-items:center;
                                gap:6px; padding:10px 20px; cursor:pointer;
                                white-space:nowrap; flex-shrink:0;
                                border-bottom: 2px solid @(_activeCategory == cat.Label ? "var(--green)" : "transparent");
                                transition: all .15s ease;
                                opacity: @(_activeCategory == cat.Label ? "1" : "0.55");">
                        <i class="@cat.Icon" style="font-size:20px; color:var(--text);"></i>
                        <span style="font-size:12px; font-weight:@(_activeCategory == cat.Label ? "700" : "500");
                                     color:var(--text);">
                            @cat.Label
                        </span>
                    </div>
                }
            </div>
        </div>

        <!-- FILTER BAR -->
        <div class="filter-bar">
            <div class="filter-row">

                <!-- SEARCH -->
                <div class="filter-input-wrap filter-input-grow">
                    <i class="bi bi-search filter-input-icon"></i>
                    <input type="text"
                           placeholder="Search by name..."
                           value="@_searchName"
                           @oninput="@(e => { _searchName = e.Value?.ToString() ?? ""; ApplyFilters(); })"
                           class="filter-input" />
                </div>

                <!-- SKILL -->
                <div class="filter-input-wrap">
                    <i class="bi bi-tools filter-input-icon"></i>
                    <input type="text"
                           placeholder="Filter by skill..."
                           value="@_searchSkill"
                           @oninput="@(e => { _searchSkill = e.Value?.ToString() ?? ""; ApplyFilters(); })"
                           class="filter-input" />
                </div>

                <!-- LOCATION -->
                <div class="filter-input-wrap">
                    <i class="bi bi-geo-alt filter-input-icon"></i>
                    <input type="text"
                           placeholder="Filter by location..."
                           value="@_searchLocation"
                           @oninput="@(e => { _searchLocation = e.Value?.ToString() ?? ""; ApplyFilters(); })"
                           class="filter-input" />
                </div>

                <!-- PRICE -->
                <div class="filter-input-wrap filter-price-wrap">
                    <i class="bi bi-cash filter-input-icon"></i>
                    <input type="number"
                           placeholder="Min"
                           value="@_minPrice"
                           @oninput="@(e => { _minPrice = decimal.TryParse(e.Value?.ToString(), out var v) ? v : null; ApplyFilters(); })"
                           class="filter-input filter-price-input" />
                    <span class="filter-price-sep">–</span>
                    <input type="number"
                           placeholder="Max"
                           value="@_maxPrice"
                           @oninput="@(e => { _maxPrice = decimal.TryParse(e.Value?.ToString(), out var v) ? v : null; ApplyFilters(); })"
                           class="filter-input filter-price-input" />
                </div>

                <!-- SORT -->
                <select @bind="_sortBy" @bind:after="ApplyFilters" class="filter-select">
                    <option value="default">Sort: Default</option>
                    <option value="rating">Highest Rated</option>
                    <option value="jobs">Most Jobs</option>
                    <option value="experience">Most Experienced</option>
                </select>

                <!-- CLEAR -->
                @if (_searchName != "" || _searchSkill != "" || _searchLocation != "" ||
                            _minRating > 0 || _activeCategory != "All" ||
                            _minPrice.HasValue || _maxPrice.HasValue)
                {
                    <button @onclick="ClearFilters" class="filter-clear">
                        <i class="bi bi-x"></i> Clear
                    </button>
                }

            </div>

            <!-- RATING + RESULTS -->
            <div class="filter-meta">
                <div class="filter-rating">
                    <span class="filter-rating-label">Min Rating:</span>
                    <MudRating @bind-SelectedValue="_minRating"
                               @bind-SelectedValue:after="ApplyFilters"
                               Size="Size.Small" />
                </div>
                <span class="filter-results">
                    @_filtered.Count result@(_filtered.Count == 1 ? "" : "s")
                </span>
            </div>
        </div>
        <!-- RESULTS -->
        <div style="padding: 32px 48px;">
            @if (_filtered.Count == 0)
            {
                <div class="empty-state">
                    <i class="bi bi-search empty-state-icon"></i>
                    <div class="empty-state-title">No technicians found</div>
                    <div class="empty-state-text">Try adjusting your filters</div>
                    <button class="btn btn-outline" @onclick="ClearFilters">Clear filters</button>
                </div>
            }
            else
            {
                <div class="tech-grid">
                    @foreach (var tech in _filtered)
                    {
                        <div class="tech-card"
                             @onclick="@(() => NavigationManager.NavigateTo($"/technicians/{tech.UserId}"))">

                            <!-- AVATAR ROW -->
                            <div class="tech-card-top">
                                <div class="tech-card-avatar">
                                    @if (!string.IsNullOrWhiteSpace(tech.ProfileImageUrl)
                                                            && Uri.IsWellFormedUriString(tech.ProfileImageUrl, UriKind.Absolute))
                                    {
                                        <img src="@tech.ProfileImageUrl" alt="@tech.FullName" />
                                    }
                                    else
                                    {
                                        @tech.FullName.FirstOrDefault()
                                    }
                                </div>
                                @if (tech.IsOnline)
                                {
                                    <span class="tech-online-badge">Online</span>
                                }
                            </div>

                            <!-- BODY -->
                            <div class="tech-card-body">
                                <div class="tech-card-name">@tech.FullName</div>
                                <div class="tech-card-location">
                                    <i class="bi bi-geo-alt"></i> @tech.Location
                                </div>
                                @if (!string.IsNullOrWhiteSpace(tech.Bio))
                                {
                                    <div class="tech-card-bio">@TextHelper.Shorten(tech.Bio)</div>
                                }
                                <div class="tech-card-skill-pills">
                                    @foreach (var skill in (tech.Skills ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="tech-skill-pill">@skill.Trim()</span>
                                    }
                                </div>
                            </div>

                            <!-- FOOTER -->
                            <div class="tech-card-footer">
                                <div class="tech-rating">
                                    <span class="tech-rating-star">★</span>
                                    <span>@(tech.AverageRating > 0 ? tech.AverageRating.ToString("0.0") : "New")</span>
                                    @if (tech.CompletedJobs > 0)
                                    {
                                        <span class="tech-jobs-count">&nbsp;(@tech.CompletedJobs jobs)</span>
                                    }
                                </div>
                                <div class="tech-card-price">
                                    @TextHelper.FormatRate(tech.HourlyRate, tech.CallOutFee)
                                </div>
                            </div>

                        </div>
                    }
                </div>
            }
        </div>
    }

</div>

@code {
    private List<TechnicianProfileDto> _technicians = [];
    private List<TechnicianProfileDto> _filtered = [];

    private const string SortDefault = "default";
    private const string SortRating = "rating";
    private const string SortJobs = "jobs";
    private const string SortExperience = "experience";

    private string _searchName = string.Empty;
    private string _searchSkill = string.Empty;
    private string _searchLocation = string.Empty;
    private string _sortBy = SortDefault;

    private int _minRating;
    private decimal? _minPrice;
    private decimal? _maxPrice;

    private bool _isLoading = true;

    private string _activeCategory = "All";

    private readonly List<(string Icon, string Label)> _categories = new()
    {
        ("bi bi-grid-fill", "All"),
        ("bi bi-wrench", "Plumbing"),
        ("bi bi-lightning-charge", "Electrical"),
        ("bi bi-snow", "AC Repair"),
        ("bi bi-house-gear", "Renovation"),
        ("bi bi-brush", "Painting"),
        ("bi bi-shield-lock", "Locksmith"),
        ("bi bi-stars", "Cleaning"),
        ("bi bi-box-seam", "Moving"),
    };

    private void SelectCategory(string category)
    {
        _activeCategory = category;
        ApplyFilters();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _technicians = (await TechnicianApiService.GetAllTechniciansAsync())
         .OrderByDescending(t => t.IsOnline)
         .ToList();
        ApplyFilters();
        _isLoading = false;

        StateHasChanged();
    }

    private void ApplyFilters()
    {
        var result = _technicians.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchName))
            result = result.Where(t =>
                t.FullName.Contains(
                    _searchName,
                    StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(_searchSkill))
            result = result.Where(t =>
                t.Skills.Contains(
                    _searchSkill,
                    StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(_searchLocation))
            result = result.Where(t =>
                t.Location.Contains(
                    _searchLocation,
                    StringComparison.OrdinalIgnoreCase));

        if (_minRating > 0)
            result = result.Where(t =>
                t.AverageRating >= _minRating);

        if (_minPrice.HasValue)
            result = result.Where(t => t.HourlyRate.HasValue && t.HourlyRate >= _minPrice.Value);

        if (_maxPrice.HasValue)
            result = result.Where(t => t.HourlyRate.HasValue && t.HourlyRate <= _maxPrice.Value);

        if (_activeCategory != "All")
            result = result.Where(t =>
                t.Skills.Contains(
                    _activeCategory,
                    StringComparison.OrdinalIgnoreCase));

        result = _sortBy switch
        {
            SortRating => result.OrderByDescending(t => t.AverageRating),
            SortJobs => result.OrderByDescending(t => t.CompletedJobs),
            SortExperience => result.OrderByDescending(t => t.YearsExperience),
            _ => result
        };

        _filtered = result.ToList();
    }

    private void ClearFilters()
    {
        _searchName = string.Empty;
        _searchSkill = string.Empty;
        _searchLocation = string.Empty;
        _sortBy = SortDefault;
        _minRating = 0;
		_minPrice = null;
		_maxPrice = null;
        ApplyFilters();
    }
}