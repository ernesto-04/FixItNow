
<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">FixItNow</a>
    </div>
</div>
<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="available-tickets">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Available Tickets
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="technician-tickets">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Technician Tickets
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <MudButton OnClick="HandleTechnicianAction" Color="Color.Success">
                Switch to Customer
            </MudButton>
        </div>
    </nav>
</div>

@code{
    @inject NavigationManager NavigationManager
    async Task HandleTechnicianAction()
    {
        NavigationManager.NavigateTo("/customer-tickets");
    }
}