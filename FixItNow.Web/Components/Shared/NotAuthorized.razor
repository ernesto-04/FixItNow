@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-12 text-center">
    <MudIcon Icon="@Icons.Material.Filled.Lock"
             Style="font-size:80px; color: var(--mud-palette-warning);"
             Class="mb-4" />
    <MudText Typo="Typo.h4" Class="mb-2">Access Denied</MudText>
    <MudText Typo="Typo.body1"
             Color="Color.Secondary"
             Class="mb-6">
        You don't have permission to view this page.
    </MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               OnClick="@(() => NavigationManager.NavigateTo("/login"))">
        Go to Login
    </MudButton>
</MudContainer>