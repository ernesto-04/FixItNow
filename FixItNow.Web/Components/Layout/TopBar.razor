@using FixItNow.Domain.Models.BookingRequest.DTOs.Technicians

@inject AppState AppState
@inject NavigationManager NavigationManager
@inject ProtectedLocalStorage LocalStorage
@inject UserApiService UserApiService
@inject AuthenticationStateProvider AuthStateProvider
@inject TechnicianApiService TechnicianApiService
@inject NotificationApiService NotificationApiService

<div class="topbar-inner" style="width:100%;">

    <!-- BRAND -->
    <span class="topbar-brand" style="cursor:pointer;"
          @onclick="@(() => NavigationManager.NavigateTo("/dashboard"))">
        FixIt<span>Now</span>
    </span>

    <!-- NAV LINKS -->
    <nav class="topbar-nav">
        <NavLink href="/dashboard" Match="NavLinkMatch.All" class="topbar-link" ActiveClass="active">
            Home
        </NavLink>

        @if (!_isAdmin)
        {
            <NavLink href="/technicians" Match="NavLinkMatch.Prefix" class="topbar-link topbar-link-highlight" ActiveClass="active">
                Browse Technicians
            </NavLink>

            @if (_isAuthenticated)
            {
                <NavLink href="@(AppState.Mode == AppState.CustomerMode ? "/my-bookings" : "/booking-requests")"
                         Match="NavLinkMatch.All" class="topbar-link" ActiveClass="active">
                    @(AppState.Mode == AppState.CustomerMode ? "My Requests" : "My Jobs")
                </NavLink>

                @if (AppState.Mode == AppState.TechnicianMode)
                {
                    <NavLink href="/edit-profile" Match="NavLinkMatch.All" class="topbar-link" ActiveClass="active">
                        Edit Profile
                    </NavLink>
                }
            }
        }
        else
        {
            <NavLink href="/admin/technicians" Match="NavLinkMatch.Prefix" class="topbar-link" ActiveClass="active">
                Admin
            </NavLink>
        }
    </nav>

    <MudSpacer />

    <!-- RIGHT SIDE -->
    @if (_topbarReady)
    {
        @if (_isAuthenticated)
        {
            @if (!_isAdmin)
            {
                @if (_isTechnician)
                {
                    <div class="topbar-mode-tabs">
                        <button class="topbar-mode-tab @(AppState.Mode == AppState.CustomerMode ? "active" : "")"
                                @onclick="@(() => SwitchMode(AppState.CustomerMode))">
                            Customer
                        </button>
                        <button class="topbar-mode-tab @(AppState.Mode == AppState.TechnicianMode ? "active" : "")"
                                @onclick="@(() => SwitchMode(AppState.TechnicianMode))">
                            Technician
                        </button>
                    </div>
                }
                else if (AppState.IsTechnicianPending)
                {
                    <span style="font-size:13px; color:var(--muted);
                                                 padding:8px 16px; border:1px solid var(--border);
                                                 border-radius:8px;">
                        ⏳ Pending approval
                    </span>
                }
                else if (AppState.IsTechnicianRejected)
                {
                    <button class="btn btn-outline"
                            style="font-size:13px; padding:8px 16px;
                                                   border-color:#ef4444; color:#ef4444;"
                            @onclick="AppState.OpenTechnicianPanel">
                        ✕ Rejected — Re-apply
                    </button>
                }
                else
                {
                    <button class="btn btn-outline" style="font-size:13px; padding:8px 16px;"
                            @onclick="AppState.OpenTechnicianPanel">
                        Become a Technician
                    </button>
                }
            }

            <!-- NOTIFICATION BELL -->
            <div style="position:relative; margin-right:8px;">
                <button @onclick="ToggleNotifications"
                        style="background:none; border:none; cursor:pointer;
                                       padding:8px; color:var(--text); position:relative;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                    @if (AppState.UnreadNotificationCount > 0)
                    {
                        <span style="position:absolute; top:4px; right:4px;
                                                 background:#ef4444; color:white; border-radius:50%;
                                                 width:16px; height:16px; font-size:10px; font-weight:700;
                                                 display:flex; align-items:center; justify-content:center;">
                            @(AppState.UnreadNotificationCount > 9 ? "9+" : AppState.UnreadNotificationCount.ToString())
                        </span>
                    }
                </button>

                @if (_showNotifications)
                {
                    <div style="position:absolute; right:0; top:44px; width:320px;
                                            background:white; border:1px solid var(--border);
                                            border-radius:var(--radius-lg); box-shadow:0 4px 20px rgba(0,0,0,0.12);
                                            z-index:1000; overflow:hidden;">
                        <div style="padding:14px 16px; border-bottom:1px solid var(--border);
                                                display:flex; align-items:center; justify-content:space-between;">
                            <span style="font-size:14px; font-weight:700; color:var(--text);">
                                Notifications
                            </span>
                            @if (AppState.UnreadNotificationCount > 0)
                            {
                                <button @onclick="MarkAllRead"
                                        style="background:none; border:none; font-size:12px;
                                                               color:var(--green); cursor:pointer; font-family:inherit;">
                                    Mark all read
                                </button>
                            }
                        </div>

                        @if (!AppState.UnreadNotifications.Any())
                        {
                            <div style="padding:32px 16px; text-align:center;
                                                        font-size:13px; color:var(--muted);">
                                No new notifications
                            </div>
                        }
                        else
                        {
                            @foreach (var n in AppState.UnreadNotifications)
                            {
                                <div @onclick="@(() => HandleNotificationClick(n))"
                                     style="padding:12px 16px; border-bottom:1px solid var(--border);
                                                                cursor:pointer; font-size:13px; color:var(--text);
                                                                transition:background .15s;"
                                     onmouseover="this.style.background='#f9f9f9'"
                                     onmouseout="this.style.background='white'">
                                    <div style="font-weight:500; margin-bottom:2px;">@n.Message</div>
                                    <div style="font-size:11px; color:var(--muted);">
                                        @n.CreatedAt.ToLocalTime().ToString("MMM dd · h:mm tt")
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }
            </div>

            <Profile />
        }
        else
        {
            <button class="btn btn-outline" style="font-size:13px; padding:8px 16px;"
                    @onclick="@(() => NavigationManager.NavigateTo("/login"))">
                Sign In
            </button>
            <button class="btn btn-primary" style="font-size:13px; padding:8px 16px;"
                    @onclick="@(() => NavigationManager.NavigateTo("/register"))">
                Sign Up
            </button>
        }
    }
    else
    {
        <div style="width:160px; height:36px;"></div>
    }
</div>

@code {
    private bool _isTechnician;
    private bool _isAuthenticated;
    private bool _topbarReady;
    private bool _isAdmin;
    private bool _showNotifications;
    private HubConnection? _hubConnection;

    protected override void OnInitialized() => AppState.OnChange += Refresh;

    private void ToggleNotifications() => _showNotifications = !_showNotifications;

    private async Task MarkAllRead()
    {
        await NotificationApiService.MarkAllReadAsync();
        AppState.ClearNotifications();
        _showNotifications = false;
    }

    private void HandleNotificationClick(NotificationDto notification)
    {
        _showNotifications = false;
        if (notification.Type == "booking")
            NavigationManager.NavigateTo(
                AppState.Mode == AppState.TechnicianMode
                    ? "/booking-requests"
                    : "/my-bookings");
        else if (notification.Type == "ticket")
            NavigationManager.NavigateTo($"/ticket/{notification.ReferenceId}");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;

        if (_isAuthenticated)
        {
            _isAdmin = authState.User.FindFirstValue("IsAdmin") == "True";
            AppState.SetAdminStatus(_isAdmin);

            if (!_isAdmin)
            {
                var status = await UserApiService.GetTechnicianStatusAsync();
                _isTechnician = status?.IsApproved == true;
                AppState.SetTechnicianStatus(
                    exists: status is not null,
                    isApproved: status?.IsApproved == true,
                    isRejected: status?.IsRejected == true);

                if (_isTechnician)
                {
                    var claim = authState.User.FindFirst(ClaimTypes.NameIdentifier);
                    if (claim is not null)
                    {
                        var profile = await TechnicianApiService.GetTechnicianByIdAsync(int.Parse(claim.Value));
                        AppState.IsTechnicianOnline = profile?.IsOnline ?? false;
                    }
                }

                var notifications = await NotificationApiService.GetUnreadAsync();
                AppState.SetNotifications(notifications);
            }
        }

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/chatHub"), options =>
            {
                options.AccessTokenProvider = async () =>
                {
                    var token = await LocalStorage.GetAsync<string>("token");
                    return token.Success ? token.Value : null;
                };
            })
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<NotificationDto>("ReceiveNotification", notification =>
        {
            AppState.AddNotification(notification);
        });

        await _hubConnection.StartAsync();

        var savedMode = await LocalStorage.GetAsync<string>("mode");
        AppState.SetMode(savedMode.Success && !string.IsNullOrWhiteSpace(savedMode.Value)
            ? savedMode.Value
            : AppState.CustomerMode);

        _topbarReady = true;
        await InvokeAsync(StateHasChanged);
    }

    private void Refresh() => InvokeAsync(StateHasChanged);

    private async Task SwitchMode(string mode)
    {
        await LocalStorage.SetAsync("mode", mode);
        AppState.SetMode(mode);
        NavigationManager.NavigateTo("/dashboard", forceLoad: true);
    }

    public async ValueTask DisposeAsync()
    {
        AppState.OnChange -= Refresh;
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }

    public void Dispose() => AppState.OnChange -= Refresh;
}