@using FixItNow.Domain.Models.BookingRequest.DTOs.Tickets

<div style="background:#fff; border:1px solid var(--border);
            border-radius:var(--radius-lg); overflow:hidden;
            display:flex; transition:box-shadow .2s ease;"
     onmouseover="this.style.boxShadow='0 2px 12px rgba(0,0,0,0.10)'"
     onmouseout="this.style.boxShadow='none'">

    <!-- LEFT BAND -->
    <div style="width:200px; min-width:200px; height:180px;
                background:@(Ticket.Status == TicketStatus.InProgress
                             ? "linear-gradient(135deg,#92400e,#b45309)"
                             : "linear-gradient(135deg,#1e3a5f,#2563eb)");
                display:flex; align-items:center; justify-content:center;
                flex-shrink:0;">
        <div style="text-align:center;">
            <div style="font-size:36px; margin-bottom:8px;">
                @TextHelper.GetCategoryEmoji(Ticket.Category)
            </div>
            <div style="font-size:12px; font-weight:600;
                        color:rgba(255,255,255,0.85);
                        text-transform:uppercase; letter-spacing:0.05em;">
                @Ticket.Category
            </div>
        </div>
    </div>

    <!-- CONTENT -->
    <div style="flex:1; padding:20px 24px; display:flex;
                flex-direction:column; justify-content:space-between;">
        <div>
            <div style="display:flex; align-items:flex-start;
                        justify-content:space-between; margin-bottom:6px;">
                <div style="font-size:18px; font-weight:700;
                            color:var(--text); letter-spacing:-0.2px;">
                    @TextHelper.Shorten(Ticket.Title)
                </div>
                <span class="badge badge-@Ticket.Status.ToString().ToLower()"
                      style="flex-shrink:0; margin-left:12px;">
                    @Ticket.Status
                </span>
            </div>
            <div style="font-size:14px; color:var(--muted); margin-bottom:12px;">
                @Ticket.CustomerName · @Ticket.CreatedAt.ToString("dd MMM yyyy")
            </div>
            <div style="font-size:13px; color:var(--muted);
                        display:flex; align-items:center; gap:6px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                </svg>
                @Ticket.Location
            </div>
        </div>

        <div style="display:flex; align-items:center; gap:8px;
                    margin-top:16px; padding-top:16px;
                    border-top:1px solid var(--border);">
            @if (Ticket.Status == TicketStatus.Assigned)
            {
                <button class="btn btn-primary"
                        style="flex:1; justify-content:center;"
                        @onclick="OnStartJob">
                    ▶ Start Job
                </button>
                <button class="btn btn-outline"
                        style="flex:1; justify-content:center; color:#ef4444;"
                        @onclick="OnCancel">
                    Cancel
                </button>
            }
            @if (Ticket.Status == TicketStatus.InProgress)
            {
                <button class="btn btn-success"
                        style="flex:1; justify-content:center;"
                        @onclick="OnCompleteJob">
                    ✓ Complete Job
                </button>
                <button class="btn btn-outline"
                        style="flex:1; justify-content:center;"
                        @onclick="OnChat">
                    💬 Chat
                </button>
                <button class="btn btn-outline"
                        style="flex:1; justify-content:center; color:#ef4444;"
                        @onclick="OnCancel">
                    Cancel
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public TechnicianTicketResponse Ticket { get; set; } = default!;
    [Parameter] public EventCallback OnStartJob { get; set; }
    [Parameter] public EventCallback OnCompleteJob { get; set; }
    [Parameter] public EventCallback OnChat { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
}