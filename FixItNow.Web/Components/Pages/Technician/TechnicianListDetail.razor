@page "/technicians/{UserId:int}"
@using FixItNow.Domain.Models.BookingRequest.DTOs.Bookings
@using FixItNow.Domain.Models.BookingRequest.DTOs.Reviews
@using FixItNow.Domain.Models.BookingRequest.DTOs.Technicians
@using FixItNow.Web.ApiServices

@inject TechnicianApiService TechnicianApiService
@inject NavigationManager NavigationManager
@inject ReviewApiService ReviewApiService
@inject BookingApiService BookingApiService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<div>

    @if (_isLoading)
    {
        <div style="display:flex; align-items:center; justify-content:center; min-height:60vh;">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else if (_profile is null)
    {
        <div class="empty-state">
            <div class="empty-state-icon">😕</div>
            <div class="empty-state-title">Technician not found</div>
        </div>
    }
    else
    {
        <div style="max-width:720px; margin:0 auto; padding:40px 48px;">

            <!-- BACK -->
            <button @onclick="@(() => NavigationManager.NavigateTo("/technicians"))"
                    style="display:inline-flex; align-items:center; gap:6px;
                               background:none; border:none; font-family:inherit;
                               font-size:14px; color:var(--muted); cursor:pointer;
                               padding:0; margin-bottom:28px;">
                ← Back to Technicians
            </button>

            <!-- PROFILE CARD -->
            <div class="profile-hero">

                <!-- BANNER -->
                <div class="profile-hero-banner"></div>

                <div class="profile-hero-body">

                    <!-- AVATAR -->
                    <div class="profile-avatar">
                        @if (!string.IsNullOrWhiteSpace(_profile.ProfileImageUrl)
                                            && Uri.IsWellFormedUriString(
                                            _profile.ProfileImageUrl, UriKind.Absolute))
                        {
                            <img src="@_profile.ProfileImageUrl"
                                 alt="@_profile.FullName" />
                        }
                        else
                        {
                            @_profile.FullName.FirstOrDefault()
                        }
                    </div>

                    <!-- NAME + LOCATION -->
                    <div style="display:flex; align-items:flex-start;
                                    justify-content:space-between; margin-bottom:4px;">
                        <div>
                            <div class="profile-name">@_profile.FullName</div>
                            <div class="profile-location">📍 @_profile.Location</div>
                            <div style="font-size:15px; font-weight:700; color:var(--green-dark); margin-top:6px;">
                                @TextHelper.FormatRate(_profile.HourlyRate, _profile.CallOutFee)
                            </div>
                        </div>
                        <!-- RATING BADGE -->
                        @if (_profile.AverageRating > 0)
                        {
                            <div style="display:flex; align-items:center; gap:5px;
                                                background:#fffbeb; border:1px solid #fde68a;
                                                border-radius:20px; padding:6px 14px;">
                                <span style="color:#f59e0b; font-size:14px;">★</span>
                                <span style="font-size:14px; font-weight:700;
                                                     color:var(--text);">
                                    @_profile.AverageRating.ToString("0.0")
                                </span>
                                <span style="font-size:12px; color:var(--muted);">
                                    (@_reviews.Count review@(_reviews.Count == 1 ? "" : "s"))
                                </span>
                            </div>
                        }
                </div>

                <!-- STATS ROW -->
                <div class="profile-stats">
                    <div class="profile-stat">
                        <div class="profile-stat-value">@_profile.YearsExperience</div>
                        <div class="profile-stat-label">Yrs Experience</div>
                    </div>
                    <div class="profile-stat">
                        <div class="profile-stat-value">@_profile.CompletedJobs</div>
                        <div class="profile-stat-label">Jobs Completed</div>
                    </div>
                    <div class="profile-stat">
                        <div class="profile-stat-value">
                            @(_profile.AverageRating > 0
                                                        ? _profile.AverageRating.ToString("0.0") + " ★"
                                                        : "—")
                        </div>
                        <div class="profile-stat-label">Avg Rating</div>
                    </div>
                </div>

                    <!-- ABOUT -->
                    <div style="margin-bottom:24px;">
                        <div class="profile-section-title">About</div>
                        <div class="profile-text">@_profile.Bio</div>
                    </div>

                    <!-- SKILLS -->
                    <div style="margin-bottom:28px;">
                        <div class="profile-section-title">Skills</div>
                        <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:10px;">
                        @foreach (var skill in _profile.Skills.Split(',',
                                                StringSplitOptions.TrimEntries |
                                                StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span style="padding:6px 14px; background:#f5f5f5;
                                                     border-radius:20px; font-size:13px;
                                                     font-weight:500; color:var(--text);">
                                    @skill
                                </span>
                            }
                        </div>
                    </div>

                    <!-- BOOK BUTTON -->
                    <button class="btn btn-primary"
                            style="width:100%; justify-content:center;
                       padding:16px; font-size:15px;"
                            @onclick="HandleBookingClick">
                        Request Booking
                    </button>

                </div>
            </div>

            <!-- REVIEWS -->
            <div style="margin-top:40px;">

                <div style="display:flex; align-items:center;
                                justify-content:space-between; margin-bottom:20px;">
                    <div style="font-size:22px; font-weight:800;
                                    color:var(--text); letter-spacing:-0.3px;">
                        Reviews
                        @if (_reviews.Count > 0)
                        {
                            <span style="font-size:15px; font-weight:400;
                                                 color:var(--muted); margin-left:8px;">
                                (@_reviews.Count)
                            </span>
                        }
                    </div>
                    @if (_profile.AverageRating > 0)
                    {
                        <div style="display:flex; align-items:center; gap:4px;
                                            font-size:15px; font-weight:600; color:var(--text);">
                            <span style="color:#f59e0b;">★</span>
                            @_profile.AverageRating.ToString("0.0") overall
                        </div>
                    }
                </div>

                @if (_reviews.Count == 0)
                {
                    <div style="text-align:center; padding:48px 20px;
                                        border:1px solid var(--border); border-radius:var(--radius-lg);">
                        <div style="font-size:40px; margin-bottom:12px;">💬</div>
                        <div style="font-size:16px; font-weight:600;
                                            color:var(--text); margin-bottom:6px;">
                            No reviews yet
                        </div>
                        <div style="font-size:13px; color:var(--muted);">
                            Be the first to leave a review after your job is complete
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var review in _reviews)
                    {
                        <div class="review-card">
                            <div style="display:flex; align-items:center;
                                                    justify-content:space-between; margin-bottom:8px;">
                                <div style="display:flex; align-items:center; gap:10px;">
                                    <div style="width:36px; height:36px; border-radius:50%;
                                                            background:linear-gradient(135deg, var(--green), var(--green-dark));
                                                            color:white; display:flex; align-items:center;
                                                            justify-content:center; font-size:14px;
                                                            font-weight:700; flex-shrink:0;">
                                        @review.CustomerName.FirstOrDefault()
                                    </div>
                                    <div>
                                        <div class="review-author">@review.CustomerName</div>
                                        <div class="review-date">
                                            @review.CreatedAt.ToString("MMM dd, yyyy")
                                        </div>
                                    </div>
                                </div>
                                <div style="display:flex; align-items:center; gap:3px;">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        var starIndex = i;
                                        <span style="color:@(starIndex <= review.Rating ? "#f59e0b" : "#e5e5e5");
                                                                     font-size:14px;">★</span>
                                    }
                                </div>
                            </div>
                            <div class="review-text">@review.Comment</div>
                        </div>
                    }
                }

            </div>

        </div>
    }

</div>

<!-- BOOKING PANEL -->
<MudDrawer Anchor="Anchor.End"
           Width="480px"
           Elevation="12"
           Variant="DrawerVariant.Temporary"
           @bind-Open="_showBookingPanel">

    <div style="height:100%; display:flex; flex-direction:column;">

        <!-- HEADER -->
        <div style="padding:24px 28px;
                    border-bottom:1px solid var(--border);
                    display:flex; align-items:center;
                    justify-content:space-between;">
            <div>
                <div style="font-size:18px; font-weight:800;
                            color:var(--text); letter-spacing:-0.3px;">
                    Request Booking
                </div>
                @if (_profile is not null)
                {
                    <div style="display:flex; align-items:center; gap:8px; margin-top:6px;">
                        <div style="width:24px; height:24px; border-radius:50%;
                                        background:linear-gradient(135deg, var(--green), var(--green-dark));
                                        color:white; display:flex; align-items:center;
                                        justify-content:center; font-size:10px; font-weight:700;">
                            @_profile.FullName.FirstOrDefault()
                        </div>
                        <div style="font-size:13px; color:var(--muted);">
                            Booking with <b style="color:var(--text);">@_profile.FullName</b>
                        </div>
                    </div>
                }
            </div>
            <button @onclick="@(() => _showBookingPanel = false)"
                    style="background:none; border:none; cursor:pointer;
                           width:32px; height:32px; border-radius:50%;
                           display:flex; align-items:center; justify-content:center;
                           color:var(--muted); transition:background .15s ease;"
                    onmouseover="this.style.background='#f5f5f5'"
                    onmouseout="this.style.background='none'">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            </button>
        </div>

        <!-- FORM -->
        <div style="flex:1; overflow-y:auto; padding:24px 28px;">

            <!-- TECHNICIAN SUMMARY CARD -->
            @if (_profile is not null)
            {
                <div style="background:#f9fafb; border:1px solid var(--border);
                                border-radius:var(--radius-md); padding:16px;
                                margin-bottom:24px; display:flex;
                                align-items:center; gap:12px;">
                    <div style="width:48px; height:48px; border-radius:50%;
                                    background:linear-gradient(135deg, var(--green), var(--green-dark));
                                    color:white; display:flex; align-items:center;
                                    justify-content:center; font-size:18px;
                                    font-weight:700; flex-shrink:0; overflow:hidden;">
                        @if (!string.IsNullOrWhiteSpace(_profile.ProfileImageUrl)
                                            && Uri.IsWellFormedUriString(
                                            _profile.ProfileImageUrl, UriKind.Absolute))
                        {
                            <img src="@_profile.ProfileImageUrl"
                                 style="width:100%; height:100%; object-fit:cover;" />
                        }
                        else
                        {
                            @_profile.FullName.FirstOrDefault()
                        }
                    </div>
                    <div>
                        <div style="font-size:14px; font-weight:700; color:var(--text);">
                            @_profile.FullName
                        </div>
                        <div style="font-size:12px; color:var(--muted); margin-top:2px;">
                            📍 @_profile.Location
                        </div>
                        @if (_profile.AverageRating > 0)
                        {
                            <div style="font-size:12px; color:#f59e0b;
                                                margin-top:2px; font-weight:600;">
                                ★ @_profile.AverageRating.ToString("0.0")
                                <span style="color:var(--muted); font-weight:400;">
                                    · @_profile.CompletedJobs jobs done
                                </span>
                            </div>
                        }
                        <div style="font-size:12px; color:var(--green-dark); margin-top:2px; font-weight:600;">
                            @TextHelper.FormatRate(_profile.HourlyRate, _profile.CallOutFee)
                        </div>
                    </div>
                </div>
            }

            <!-- TITLE -->
            <div style="margin-bottom:18px;">
                <label style="display:block; font-size:13px; font-weight:600;
                              color:var(--text); margin-bottom:6px;">
                    Job Title
                </label>
                <input type="text"
                       placeholder="e.g. Fix leaking pipe in bathroom"
                       value="@_booking.Title"
                       @oninput="@(e => _booking.Title = e.Value?.ToString() ?? "")"
                       style="width:100%; padding:12px 16px;
                              border:1.5px solid var(--border);
                              border-radius:var(--radius-md);
                              font-size:14px; font-family:inherit;
                              outline:none; color:var(--text);
                              transition:border-color .15s ease;"
                       onfocus="this.style.borderColor='var(--green)'"
                       onblur="this.style.borderColor='var(--border)'" />
            </div>

            <!-- CATEGORY -->
            <div style="margin-bottom:18px;">
                <label style="display:block; font-size:13px; font-weight:600;
                              color:var(--text); margin-bottom:6px;">
                    Category
                </label>
                <input type="text"
                       placeholder="e.g. Plumbing, Electrical, AC Repair"
                       value="@_booking.Category"
                       @oninput="@(e => _booking.Category = e.Value?.ToString() ?? "")"
                       style="width:100%; padding:12px 16px;
                              border:1.5px solid var(--border);
                              border-radius:var(--radius-md);
                              font-size:14px; font-family:inherit;
                              outline:none; color:var(--text);
                              transition:border-color .15s ease;"
                       onfocus="this.style.borderColor='var(--green)'"
                       onblur="this.style.borderColor='var(--border)'" />
                <!-- QUICK CATEGORY PILLS -->
                <div style="display:flex; gap:6px; flex-wrap:wrap; margin-top:8px;">
                    @foreach (var cat in new[] { "Plumbing", "Electrical", "AC Repair", "Cleaning", "Painting" })
                    {
                        <button type="button"
                                @onclick="@(() => _booking.Category = cat)"
                                style="padding:4px 12px; background:@(_booking.Category == cat ? "var(--green)" : "#f5f5f5");
                                           color:@(_booking.Category == cat ? "white" : "var(--text)");
                                           border:none; border-radius:20px; font-size:12px;
                                           font-weight:500; cursor:pointer; font-family:inherit;
                                           transition:all .15s ease;">
                            @cat
                        </button>
                    }
                </div>
            </div>

            <!-- DESCRIPTION -->
            <div style="margin-bottom:18px;">
                <label style="display:block; font-size:13px; font-weight:600;
                              color:var(--text); margin-bottom:6px;">
                    Description
                    <span style="font-weight:400; color:var(--muted);">
                        — describe the problem in detail
                    </span>
                </label>
                <textarea placeholder="Describe what needs to be done, any relevant details, urgency etc."
                          value="@_booking.Description"
                          @oninput="@(e => _booking.Description = e.Value?.ToString() ?? "")"
                          rows="4"
                          style="width:100%; padding:12px 16px;
                                 border:1.5px solid var(--border);
                                 border-radius:var(--radius-md);
                                 font-size:14px; font-family:inherit;
                                 outline:none; color:var(--text); resize:vertical;
                                 transition:border-color .15s ease;"
                          onfocus="this.style.borderColor='var(--green)'"
                          onblur="this.style.borderColor='var(--border)'">
                </textarea>
            </div>

            <!-- LOCATION -->
            <div style="margin-bottom:8px;">
                <label style="display:block; font-size:13px; font-weight:600;
                              color:var(--text); margin-bottom:6px;">
                    Location
                </label>
                <div style="position:relative;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                         viewBox="0 0 24 24" fill="none" stroke="var(--muted)"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         style="position:absolute; left:14px; top:50%;
                                transform:translateY(-50%); pointer-events:none;">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                        <circle cx="12" cy="10" r="3" />
                    </svg>
                    <input type="text"
                           placeholder="Your address or area"
                           value="@_booking.Location"
                           @oninput="@(e => _booking.Location = e.Value?.ToString() ?? "")"
                           style="width:100%; padding:12px 16px 12px 36px;
                                  border:1.5px solid var(--border);
                                  border-radius:var(--radius-md);
                                  font-size:14px; font-family:inherit;
                                  outline:none; color:var(--text);
                                  transition:border-color .15s ease;"
                           onfocus="this.style.borderColor='var(--green)'"
                           onblur="this.style.borderColor='var(--border)'" />
                </div>
            </div>

            <!-- ERROR -->
            @if (!string.IsNullOrWhiteSpace(_bookingError))
            {
                <div style="background:#FEE2E2; border:1px solid #FCA5A5;
                                border-radius:var(--radius-md); padding:12px 16px;
                                font-size:13px; color:#991B1B; margin-top:16px;
                                display:flex; align-items:center; gap:8px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="12" />
                        <line x1="12" y1="16" x2="12.01" y2="16" />
                    </svg>
                    @_bookingError
                </div>
            }

        </div>

        <!-- STICKY FOOTER -->
        <div style="padding:20px 28px;
                    border-top:1px solid var(--border);
                    background:#fff;">
            <button class="btn btn-primary"
                    style="width:100%; justify-content:center;
               padding:16px; font-size:15px;
               @(_profile is not null && !_profile.IsOnline
                                       ? "opacity:0.5; cursor:not-allowed;"
                                       : "")"
                    disabled="@(_isSubmittingBooking || (_profile is not null && !_profile.IsOnline))"
                    @onclick="SubmitBookingAsync">
                @if (_isSubmittingBooking)
                {
                    <MudProgressCircular Size="Size.Small"
                                         Indeterminate="true"
                                         Class="mr-2" />
                    <span>Sending request...</span>
                }
                else
                {
                    <span>Send Booking Request</span>
                }
            </button>
            <div style="text-align:center; margin-top:10px;
            font-size:12px; color:var(--muted);">
                @if (_profile is not null && !_profile.IsOnline)
                {
                    <span style="color:#991B1B;">
                        This technician is currently offline and not accepting bookings
                    </span>
                }
                else
                {
                    <span>The technician will confirm or decline your request</span>
                }
            </div>
        </div>

    </div>

</MudDrawer>

@code {
    [Parameter]
    public int UserId { get; set; }
    [Parameter]
    [SupplyParameterFromQuery(Name = "openBooking")]
    public bool OpenBooking { get; set; }

    private TechnicianProfileDto? _profile;
    private List<ReviewDto> _reviews = [];
    private bool _isLoading = true;
    private bool _showBookingPanel;
    private bool _isSubmittingBooking;
    private string? _bookingError;
    private CreateBookingRequestDto _booking = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var profileTask = TechnicianApiService.GetTechnicianByIdAsync(UserId);
        var reviewsTask = ReviewApiService.GetReviewsByTechnicianAsync(UserId);
        await Task.WhenAll(profileTask, reviewsTask);
        _profile = profileTask.Result;
        _reviews = reviewsTask.Result ?? [];
        _isLoading = false;

        if (OpenBooking)
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated == true)
            {
                _booking = new() { TechnicianId = UserId };
                _bookingError = null;
                _showBookingPanel = true;
            }
        }

        StateHasChanged();
    }

    private async Task HandleBookingClick()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            var returnUrl = Uri.EscapeDataString($"/technicians/{UserId}?openBooking=true");
            NavigationManager.NavigateTo($"/login?returnUrl={returnUrl}", forceLoad: true);
            return;
        }
        _booking = new() { TechnicianId = UserId };
        _bookingError = null;
        _showBookingPanel = true;
    }

    private async Task SubmitBookingAsync()
    {
        if (string.IsNullOrWhiteSpace(_booking.Title) ||
            string.IsNullOrWhiteSpace(_booking.Description) ||
            string.IsNullOrWhiteSpace(_booking.Category) ||
            string.IsNullOrWhiteSpace(_booking.Location))
        {
            _bookingError = "Please fill in all fields.";
            return;
        }

        _isSubmittingBooking = true;
        _bookingError = null;

        try
        {
            var (success, error) = await BookingApiService.CreateBookingAsync(_booking);
            if (success)
            {
                _showBookingPanel = false;
                _booking = new() { TechnicianId = UserId };
                Snackbar.Add(
                    "Booking request sent! Waiting for technician confirmation.",
                    Severity.Success);
            }
            else
            {
                _bookingError = error;
            }
        }
        finally
        {
            _isSubmittingBooking = false;
        }
    }
}