@page "/technician-tickets/{Id:int}"

@inject HttpClient Http
@inject ProtectedLocalStorage LocalStorage
@inject NavigationManager NavigationManager
@inject TicketApiService TicketApiService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">

    @if (ticket == null)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <!-- TITLE -->
        <MudText Typo="Typo.h4" Class="mb-2">
            @ticket.Title
        </MudText>

        <!-- CATEGORY + STATUS -->
        <div class="mb-4">
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                @ticket.Category
            </MudChip>

            <MudChip T="string" Class="ml-2"
                     Color="@GetStatusColor(ticket.Status)">
                @ticket.Status
            </MudChip>
        </div>

        <!-- IMAGE -->
        @if (ticket.ImageUrls != null && ticket.ImageUrls.Any())
        {
            <MudGrid Class="mb-4">
                @foreach (var img in ticket.ImageUrls)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudImage Src="@img"
                                  Style="width:100%; height:200px; object-fit:cover; border-radius:12px;" />
                    </MudItem>
                }
            </MudGrid>
        }

        <MudGrid>

            <!-- LEFT -->
            <MudItem xs="12" md="8">

                <MudPaper Class="pa-4 rounded-xl" Elevation="2">

                    <MudText Typo="Typo.h6" Class="mb-2">
                        Description
                    </MudText>

                    <MudText Typo="Typo.body1" Class="mb-4">
                        @ticket.Description
                    </MudText>

                    <MudDivider Class="my-3" />

                    <MudText Typo="Typo.subtitle2">
                        Location
                    </MudText>

                    <MudText Typo="Typo.body2">
                        @ticket.Location
                    </MudText>

                </MudPaper>

            </MudItem>

            <!-- RIGHT SIDEBAR -->
            <MudItem xs="12" md="4">

                <MudPaper Class="pa-4 rounded-xl" Elevation="2">

                    <MudText Typo="Typo.h6" Class="mb-3">
                        Job Info
                    </MudText>

                    <MudText Typo="Typo.body2">
                        <b>Status:</b> @ticket.Status
                    </MudText>

                    <MudText Typo="Typo.body2">
                        <b>Category:</b> @ticket.Category
                    </MudText>

                    <MudText Typo="Typo.body2">
                        <b>Created:</b> @ticket.CreatedAt.ToString("dd MMM yyyy")
                    </MudText>

                    <MudDivider Class="my-3" />

                    <MudText Typo="Typo.subtitle2">
                        Customer
                    </MudText>

                    <MudText Typo="Typo.body2" Class="mb-3">
                        @ticket.CustomerName
                    </MudText>

                    <!-- ACTIONS -->
                    @if (ticket.Status == TicketStatus.Assigned)
                    {
                        <MudButton FullWidth="true"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="@(() => UpdateStatusAsync(ticket.Id, TicketStatus.InProgress))">
                            Start Job
                        </MudButton>
                    }
                    else if (ticket.Status == TicketStatus.InProgress)
                    {
                        <MudButton FullWidth="true"
                                   Variant="Variant.Filled"
                                   Color="Color.Success"
                                   OnClick="@(() => UpdateStatusAsync(ticket.Id, TicketStatus.Completed))">
                            Complete Job
                        </MudButton>

                        <MudButton FullWidth="true"
                                   Class="mt-2"
                                   Variant="Variant.Outlined"
                                   Color="Color.Info">
                            Chat Customer
                        </MudButton>
                    }
                    else if (ticket.Status == TicketStatus.Completed)
                    {
                        <MudChip T="string" Color="Color.Success" Variant="Variant.Filled">
                            Completed
                        </MudChip>
                    }

                </MudPaper>

            </MudItem>

        </MudGrid>

        <!-- BACK -->
        <MudButton Class="mt-4"
                   Variant="Variant.Text"
                   OnClick="@(() => NavigationManager.NavigateTo("/technician-tickets"))">
            ← Back
        </MudButton>
    }

</MudContainer>

@code {

    [Parameter]
    public int Id { get; set; }

    private TechnicianTicketResponse? ticket;

    private bool isLoading = true;

    private bool isUpdating;

    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadTicketAsync();

        StateHasChanged();
    }

    private async Task LoadTicketAsync()
    {
        try
        {
            isLoading = true;

            ticket =
                await TicketApiService.GetTechnicianTicketDetailAsync(Id);

            if (ticket is null)
            {
                errorMessage = "Ticket not found.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateStatusAsync(
        int ticketId,
        TicketStatus status)
    {
        try
        {
            isUpdating = true;

            var success =
                await TicketApiService
                    .UpdateTicketStatusAsync(
                        ticketId,
                        status);

            if (!success)
            {
                errorMessage =
                    "Failed to update ticket status.";

                return;
            }

            await LoadTicketAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isUpdating = false;
        }
    }

    private static Color GetStatusColor(
        TicketStatus status) =>
        status switch
        {
            TicketStatus.Assigned => Color.Info,
            TicketStatus.InProgress => Color.Warning,
            TicketStatus.Completed => Color.Success,
            _ => Color.Default
        };
}