@page "/dashboard"
@using FixItNow.Domain.Models.BookingRequest.Tickets
@using FixItNow.Domain.Models.Bookings
@using FixItNow.Web.ApiServices

@inject AppState AppState
@inject NavigationManager NavigationManager
@inject TechnicianApiService TechnicianApiService
@inject TicketApiService TicketApiService
@inject BookingApiService BookingApiService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@implements IDisposable

@if (_isLoading)
{
    <div style="display:flex; align-items:center; justify-content:center; min-height:60vh;">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (AppState.Mode == AppState.CustomerMode)
{
    <!-- CUSTOMER HERO -->
    <div class="hero">
        <div class="hero-bg-image"></div>
        <div class="hero-bg"></div>
        <div class="hero-content">

            <div class="hero-eyebrow">FixItNow — Service Marketplace</div>

            <h1 class="hero-title">
                Find the right professional,<br />
                <span class="hero-title-accent">right away.</span>
            </h1>

            <p class="hero-subtitle">
                Book trusted technicians for any home service.
                Fast, reliable, and vetted.
            </p>

            <div class="hero-cta-row">
                <button class="btn-primary" @onclick="ScrollToServices">
                    Browse services
                </button>
                <button class="btn-ghost" @onclick="ScrollToHowItWorks">
                    How it works
                </button>
            </div>

            <div class="hero-trust">
                <span class="hero-trust-item">10,000+ bookings completed</span>
                <span class="hero-trust-item">Avg. 4.8★ rating</span>
                <span class="hero-trust-item">Same-day available</span>
            </div>

        </div>
    </div>

    <!-- HOW IT WORKS -->
    <div class="how-it-works" id="how-it-works-section">
        <div class="hiw-header">
            <h2 class="hiw-title">How It Works</h2>
            <div class="hiw-underline"></div>
        </div>
        <div class="hiw-steps">
            <div class="hiw-connector"></div>
            <div class="hiw-step">
                <div class="hiw-icon-wrap">
                    <span class="hiw-step-number">1</span>
                    <i class="bi bi-person-bounding-box" style="font-size:26px;"></i>
                </div>
                <h3 class="hiw-step-title">Browse Technicians</h3>
                <p class="hiw-step-desc">Find approved professionals and request a booking.</p>
            </div>
            <div class="hiw-step">
                <div class="hiw-icon-wrap">
                    <span class="hiw-step-number">2</span>
                    <i class="bi bi-calendar-plus" style="font-size:26px;"></i>
                </div>
                <h3 class="hiw-step-title">Request a Booking</h3>
                <p class="hiw-step-desc">Submit your request. The technician reviews and accepts.</p>
            </div>
            <div class="hiw-step">
                <div class="hiw-icon-wrap">
                    <span class="hiw-step-number">3</span>
                    <i class="bi bi-tools" style="font-size:26px;"></i>
                </div>
                <h3 class="hiw-step-title">Job in Progress</h3>
                <p class="hiw-step-desc">Technician arrives and completes the job on-site.</p>
            </div>
            <div class="hiw-step">
                <div class="hiw-icon-wrap">
                    <span class="hiw-step-number">4</span>
                    <i class="bi bi-star" style="font-size:26px;"></i>
                </div>
                <h3 class="hiw-step-title">Done & Review</h3>
                <p class="hiw-step-desc">Job complete. Leave a review to help others choose.</p>
            </div>
        </div>
    </div>

    <!-- CATEGORIES -->
    <div class="section" id="services-section">
        <div class="category-section-header">
            <div>
                <div class="section-title" style="margin-bottom:4px;">Professional Services</div>
                <div class="category-subtitle">Anything your home needs, handled by experts.</div>
            </div>
            <span class="category-see-all" @onclick="@(() => NavigationManager.NavigateTo("/technicians"))">
                See all categories →
            </span>
        </div>
        <div class="category-grid">
            @foreach (var cat in _categories)
            {
                <div class="category-card"
                     @onclick="@(() => NavigationManager.NavigateTo("/technicians"))">
                    <i class="@cat.Icon category-card-icon" style="font-size:24px;"></i>
                    <span class="category-card-label">@cat.Label</span>
                </div>
            }
        </div>
    </div>
    <div class="section-divider"></div>

    <!-- TRUST BAR -->
    <div class="trust-bar">
        <div class="trust-item">
            <i class="bi bi-shield-check" style="font-size:22px;"></i>
            <div>
                <div class="trust-title">Verified Pros</div>
                <div class="trust-desc">Every technician passes a rigorous background check.</div>
            </div>
        </div>
        <div class="trust-item">
            <i class="bi bi-star" style="font-size:22px;"></i>
            <div>
                <div class="trust-title">Real Reviews</div>
                <div class="trust-desc">100% genuine feedback from real customers like you.</div>
            </div>
        </div>
        <div class="trust-item">
            <i class="bi bi-calendar-check" style="font-size:22px;"></i>
            <div>
                <div class="trust-title">Easy Booking</div>
                <div class="trust-desc">Book a service in under 60 seconds via our app.</div>
            </div>
        </div>
        <div class="trust-item">
            <i class="bi bi-geo-alt" style="font-size:22px;"></i>
            <div>
                <div class="trust-title">Track Your Job</div>
                <div class="trust-desc">Live updates and technician tracking to your door.</div>
            </div>
        </div>
    </div>

    <!-- JOIN AS PRO -->
    @if (!_isAuthenticated)
    {
        <div class="join-pro-section">
            <div class="join-pro-image"></div>
            <div class="join-pro-content">
                <div class="join-pro-eyebrow">Earn as a Fixer</div>
                <p class="join-pro-text">
                    Are you a skilled technician? Join the <span style="color:var(--green);font-weight:600;">FixItNow</span> platform and grow your business.
                    Reach thousands of customers and manage your schedule with ease.
                </p>
                <ul class="join-pro-list">
                    <li><i class="bi bi-check-circle" style="font-size:16px;color:var(--green);"></i> Flexible working hours</li>
                    <li><i class="bi bi-check-circle" style="font-size:16px;color:var(--green);"></i> Weekly payouts</li>
                    <li><i class="bi bi-check-circle" style="font-size:16px;color:var(--green);"></i> Free insurance coverage</li>
                </ul>
                <button class="btn-join-pro"
                        @onclick="@(() => NavigationManager.NavigateTo("/register"))">
                    Join as Pro
                </button>
            </div>
        </div>
    }
}

else
{
    @if (AppState.Mode == AppState.TechnicianMode)
    {
        <!-- TECHNICIAN ALERT BAR -->
        @if (_pendingBookings > 0)
        {
            <div class="tech-alert-bar">
                <i class="bi bi-bell-fill"></i>
                You have <strong>@_pendingBookings pending booking request@(_pendingBookings == 1 ? "" : "s")</strong> waiting for your response.
                <button class="tech-alert-link"
                        @onclick="@(() => NavigationManager.NavigateTo("/booking-requests"))">
                    View requests →
                </button>
            </div>
        }

        <!-- TECHNICIAN HERO -->
        <div class="hero">
            <div class="hero-bg-image"></div>
            <div class="hero-bg"></div>
            <div class="hero-content">
                <div class="hero-eyebrow">Technician Workspace</div>
                <h1 class="hero-title">
                    Grow your business with<br />FixItNow.
                </h1>
                <p class="hero-subtitle">
                    Manage bookings, track active jobs,
                    and build your reputation.
                </p>
                <div class="hero-cta-row">
                    <button class="btn-primary"
                            @onclick="@(() => NavigationManager.NavigateTo("/booking-requests"))">
                        <i class="bi bi-inbox"></i>
                        View Booking Requests
                        @if (_pendingBookings > 0)
                        {
                            <span class="hero-cta-badge">@_pendingBookings</span>
                        }
                    </button>
                    <button class="btn-ghost"
                            @onclick="@(() => NavigationManager.NavigateTo("/edit-profile"))">
                        Edit Profile
                    </button>
                </div>
                <div class="hero-trust">
                    <span class="hero-trust-item">Manage your schedule</span>
                    <span class="hero-trust-item">Weekly payouts</span>
                    <span class="hero-trust-item">Free insurance coverage</span>
                </div>
            </div>
        </div>
    }
}

@code {
    private string _fullName = string.Empty;
    private bool _isLoading = true;
    private bool _jsReady = false;
    private bool _isAuthenticated = false;
    private int _pendingBookings = 0;

    private readonly List<(string Icon, string Label)> _categories = new()
    {
        ("bi bi-wrench", "Plumbing"),
        ("bi bi-lightning-charge", "Electrical"),
        ("bi bi-snow", "AC Repair"),
        ("bi bi-stars", "Cleaning"),
        ("bi bi-hammer", "Handyman"),
        ("bi bi-bug", "Pest Control"),
        ("bi bi-brush", "Painting"),
        ("bi bi-house-gear", "Home Reno"),
    };

    protected override void OnInitialized()
    {
        AppState.OnChange += OnModeChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= OnModeChanged;
    }

    private void OnModeChanged()
    {
        _isLoading = true;
        InvokeAsync(async () =>
        {
            try
            {
                await LoadAsync();
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsReady = true;
            await LoadAsync();
            StateHasChanged();
        }

    }

    private async Task LoadAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;

        _fullName = authState.User.FindFirst("FullName")?.Value
            ?? authState.User.FindFirst(ClaimTypes.Name)?.Value
            ?? "there";

        if (_isAuthenticated && AppState.Mode == AppState.TechnicianMode)
        {
            var bookings = await BookingApiService.GetTechnicianBookingsAsync();
            _pendingBookings = bookings.Count(b => b.Status == BookingStatus.Pending);
        }

        _isLoading = false;
    }

    private async Task ScrollToServices()
    {
        if (!_jsReady) return;
        try
        {
            await JS.InvokeVoidAsync("scrollToElement", "services-section");
        }
        catch { }
    }

    private async Task ScrollToHowItWorks()
    {
        if (!_jsReady) return;
        try
        {
            await JS.InvokeVoidAsync("scrollToElement", "how-it-works-section");
        }
        catch { }
    }
}