@page "/create-ticket"

@inject HttpClient Http
@inject ProtectedLocalStorage LocalStorage
@inject AuthenticatedHttpService AuthenticatedHttpService
@inject TicketApiService TicketApiService

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6 mb-10">

    <MudPaper Class="pa-6" Elevation="3">

        <MudText Typo="Typo.h5" GutterBottom="true">
            Create a Service Request
        </MudText>

        <MudStepper @bind-ActiveIndex="step"
                    Elevation="0"
                    Class="mb-4">

            <MudStep Label="Category" />
            <MudStep Label="Photos" />
            <MudStep Label="Details" />
            <MudStep Label="Confirm" />

        </MudStepper>

        <MudDivider Class="mb-6" />

        @if (step == 0)
        {
            <MudText Typo="Typo.subtitle1" Class="mb-3">
                What do you need help with?
            </MudText>

            <MudGrid>

                @foreach (var category in categories)
                {
                    <MudItem xs="6" sm="4">

                        <MudPaper Class="@GetCategoryClass(ticket.Category ?? "", category)"
                                  Style="cursor:pointer"
                                  @onclick="() => ticket.Category = category">

                            <MudText Align="Align.Center">
                                @category
                            </MudText>

                        </MudPaper>

                    </MudItem>
                }

            </MudGrid>
        }

        @if (step == 1)
        {
            <MudText Typo="Typo.subtitle1" Class="mb-3">
                Upload photos (optional)
            </MudText>

            <label for="fileInput" style="width:100%">

                <MudPaper Class="pa-6 d-flex flex-column align-center justify-center upload-box"
                          Style="cursor:pointer">

                    <MudIcon Icon="@Icons.Material.Filled.CloudUpload"
                             Size="Size.Large" />

                    <MudText Typo="Typo.subtitle2" Class="mt-2">
                        Click to upload photos
                    </MudText>

                    <MudText Typo="Typo.caption">
                        Max 5 images • 10MB each
                    </MudText>

                </MudPaper>

            </label>

            <InputFile id="fileInput"
                       OnChange="HandleFileSelected"
                       multiple
                       hidden />

            @if (uploadedImages.Any())
            {
                <MudGrid Class="mt-4">

                    @foreach (var image in uploadedImages.Select((value, index) => new { value, index }))
                    {
                        <MudItem xs="4">

                            <MudPaper Class="pa-1 position-relative preview-box">

                                <MudImage Src="@image.value.PreviewUrl"
                                          Class="preview-img" />

                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               Class="remove-btn"
                                               OnClick="() => RemoveImage(image.index)" />

                            </MudPaper>

                        </MudItem>
                    }

                </MudGrid>
            }
        }

        @if (step == 2)
        {
            <MudStack Spacing="3">

                <MudTextField Label="Title"
                              @bind-Value="ticket.Title"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Required="true" />

                <MudTextField Label="Description"
                              @bind-Value="ticket.Description"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Lines="4"
                              Required="true" />

                <MudTextField Label="Location"
                              @bind-Value="ticket.Location"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Required="true" />

            </MudStack>
        }

        @if (step == 3)
        {
            <MudText Typo="Typo.subtitle1" Class="mb-3">
                Review your request
            </MudText>

            <MudPaper Class="pa-4 mud-theme-background-grey">

                <MudList T="string" Dense="true">

                    <MudListItem>
                        <strong>Category:</strong>&nbsp; @ticket.Category
                    </MudListItem>

                    <MudListItem>
                        <strong>Title:</strong>&nbsp; @ticket.Title
                    </MudListItem>

                    <MudListItem>
                        <strong>Description:</strong>&nbsp; @ticket.Description
                    </MudListItem>

                    <MudListItem>
                        <strong>Location:</strong>&nbsp; @ticket.Location
                    </MudListItem>

                    <MudListItem>
                        <strong>Images:</strong>&nbsp; @uploadedImages.Count
                    </MudListItem>

                </MudList>

            </MudPaper>
        }

        <MudStack Row="true"
                  Justify="Justify.SpaceBetween"
                  Class="mt-6">

            <MudButton Variant="Variant.Text"
                       Disabled="step == 0 || isSubmitting"
                       OnClick="PrevStep">

                Back

            </MudButton>

            @if (step < 3)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="isSubmitting"
                           OnClick="NextStep">

                    Next

                </MudButton>
            }
            else
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           Disabled="isSubmitting"
                           Loading="isSubmitting"
                           OnClick="CreateAsync">

                    Submit

                </MudButton>
            }

        </MudStack>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <MudAlert Severity="Severity.Info"
                      Dense="true"
                      Class="mt-4">

                @message

            </MudAlert>
        }

    </MudPaper>

</MudContainer>

@code {
    private int step;

    private bool isSubmitting;

    private string? message;

    private readonly CreateTicketRequest ticket = new();

    private readonly List<string> categories =
    [
        "Electrical",
        "Plumbing",
        "Cleaning",
        "AC Repair",
        "General"
    ];

    private readonly List<UploadedImage> uploadedImages = [];

    private const int MaxFiles = 5;
    private const long MaxFileSize = 10 * 1024 * 1024;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var remainingSlots = MaxFiles - uploadedImages.Count;

        foreach (var file in e.GetMultipleFiles(remainingSlots))
        {
            if (uploadedImages.Count >= MaxFiles)
                break;

            if (file.Size > MaxFileSize)
                continue;

            using var stream = file.OpenReadStream(MaxFileSize);
            using var memoryStream = new MemoryStream();

            await stream.CopyToAsync(memoryStream);

            var bytes = memoryStream.ToArray();

            uploadedImages.Add(new UploadedImage
            {
                Name = file.Name,
                ContentType = file.ContentType,
                Data = bytes,
                PreviewUrl =
                    $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}"
            });
        }
    }

    private static string GetCategoryClass(
        string currentCategory,
        string selectedCategory)
    {
        return currentCategory == selectedCategory
            ? "pa-4 mud-elevation-8 rounded-lg text-center border border-primary"
            : "pa-4 mud-elevation-2 rounded-lg text-center";
    }

    private void NextStep()
    {
        if (step < 2)
            step++;
    }

    private void PrevStep()
    {
        if (step > 0)
            step--;
    }

    private void RemoveImage(int index)
    {
        if (index < 0 || index >= uploadedImages.Count)
            return;

        uploadedImages.RemoveAt(index);
    }

    private async Task CreateAsync()
    {
        try
        {
            isSubmitting = true;
            message = null;

            var result =
                await TicketApiService.CreateTicketAsync(
                    ticket,
                    uploadedImages);

            if (result is null)
            {
                message = "Failed to create ticket.";
                return;
            }

            message =
                $"Ticket #{result.Id} created successfully!";

            ResetForm();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
    private void ResetForm()
    {
        ticket.Title = string.Empty;
        ticket.Description = string.Empty;
        ticket.Category = string.Empty;
        ticket.Location = string.Empty;

        uploadedImages.Clear();

        step = 0;
    }
}