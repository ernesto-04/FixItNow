@page "/ticket/{Id:int}"

@inject HttpClient Http
@inject ProtectedLocalStorage LocalStorage
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject AuthenticatedHttpService AuthenticatedHttpService
@inject TicketApiService TicketApiService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">

    @if (isLoading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <MudAlert Severity="Severity.Error">
            @errorMessage
        </MudAlert>
    }
    else if(ticket is not null)
    {
        <!-- TITLE -->
        <MudText Typo="Typo.h4" Class="mb-2">
            @ticket.Title
        </MudText>

        <!-- STATUS + CATEGORY -->
        <div class="mb-4">
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                @ticket.Category
            </MudChip>

            <MudChip Class="ml-2"
                     T="string"
                     Color="@GetStatusColor(ticket.Status)">
                @ticket.Status
            </MudChip>
        </div>

        <!-- IMAGE GALLERY -->
        @if (ticket.ImageUrls != null && ticket.ImageUrls.Any())
        {
            <MudGrid Class="mb-4">
                @foreach (var image in ticket.ImageUrls)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudImage Src="@image"
                                  Style="width:100%; height:200px; object-fit:cover; border-radius:12px;" />
                    </MudItem>
                }
            </MudGrid>
        }

        <MudGrid>

            <!-- LEFT SIDE -->
            <MudItem xs="12" md="8">

                <MudPaper Class="pa-4 rounded-xl" Elevation="2">

                    <MudText Typo="Typo.h6" Class="mb-2">
                        Description
                    </MudText>

                    <MudText Typo="Typo.body1">
                        @ticket.Description
                    </MudText>

                    <MudDivider Class="my-4" />

                    <MudText Typo="Typo.subtitle2">
                        Location
                    </MudText>

                    <MudText Typo="Typo.body2">
                        @ticket.Location
                    </MudText>

                </MudPaper>

            </MudItem>

            <!-- RIGHT SIDE (SIDEBAR) -->
            <MudItem xs="12" md="4">

                <MudPaper Class="pa-4 rounded-xl" Elevation="2">

                    <MudText Typo="Typo.h6" Class="mb-3">
                        Ticket Info
                    </MudText>

                    <MudText Typo="Typo.body2">
                        <b>Status:</b> @ticket.Status
                    </MudText>

                    <MudText Typo="Typo.body2">
                        <b>Category:</b> @ticket.Category
                    </MudText>

                    <MudText Typo="Typo.body2">
                        <b>Created:</b> @ticket.CreatedAt.ToString("dd MMM yyyy")
                    </MudText>

                    <MudDivider Class="my-3" />

                    <MudText Typo="Typo.subtitle2">
                        Technician
                    </MudText>

                    <MudText Typo="Typo.body2" Class="mb-3">
                        @(ticket.TechnicianName ?? "Not assigned")
                    </MudText>

                    @if (ticket.Status == TicketStatus.Completed)
                    {
                        <MudButton FullWidth="true"
                                   Variant="Variant.Outlined"
                                   Color="Color.Primary">
                            Leave Review
                        </MudButton>
                    }

                </MudPaper>

            </MudItem>

        </MudGrid>

        <!-- BACK BUTTON -->
        <MudButton Class="mt-4"
                   Variant="Variant.Text"
                   OnClick="@(() => NavigationManager.NavigateTo("/customer-tickets"))">
            ← Back to Tickets
        </MudButton>
    }

</MudContainer>

@code {

    [Parameter]
    public int Id { get; set; }

    private CustomerTicketResponse? ticket;

    private int currentUserId;

    private bool isLoading = true;

    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadCurrentUserAsync();
        await LoadTicketAsync();

        StateHasChanged();
    }

    private async Task LoadCurrentUserAsync()
    {
        var result =
            await LocalStorage.GetAsync<int>("userId");

        if (result.Success)
        {
            currentUserId = result.Value;
        }
    }

    private async Task LoadTicketAsync()
    {
        try
        {
            isLoading = true;

            ticket = await TicketApiService.GetCustomerTicketAsync(Id);

            if (ticket is null)
            {
                errorMessage = "Ticket not found.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private static Color GetStatusColor(
        TicketStatus status) =>
        status switch
        {
            TicketStatus.Unassigned => Color.Default,
            TicketStatus.Assigned => Color.Info,
            TicketStatus.InProgress => Color.Warning,
            TicketStatus.Completed => Color.Success,
            _ => Color.Default
        };
}