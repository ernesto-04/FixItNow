@using System.Security.Claims
@using FixItNow.Domain.Models.DTOs
@using FixItNow.Web.Components.Custom.Profile
@inherits LayoutComponentBase

@inject ProtectedLocalStorage LocalStorage
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject AppState AppState
@inject IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider

<MudThemeProvider Theme="ThemeHelper.Default" />
<MudPopoverProvider />
<MudSnackbarProvider />

<MudLayout>

    <!-- 🔝 TOP BAR -->
    <MudAppBar Elevation="1" Color="Color.Primary">

        <MudIconButton Icon="@(_drawerOpen? Icons.Material.Filled.ArrowBack : Icons.Material.Filled.Menu)"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />

        <MudSpacer />

        <MudButton OnClick="HandleSwitch"
                   Color="Color.Success"
                   Variant="Variant.Filled"
                   Class="mr-2">

            @(AppState.Mode == "technician"
                        ? "Switch to Customer"
                        : "Become a Technician")

        </MudButton>

        <Profile />

    </MudAppBar>

    <!-- 📂 LEFT NAVIGATION -->
    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Responsive">

        <NavMenu />

    </MudDrawer>

    <!-- 👉 RIGHT SLIDE PANEL -->
    <MudDrawer Anchor="Anchor.End"
               Width="420px"
               Elevation="10"
               Variant="DrawerVariant.Temporary"
               Class="technician-panel"
               @bind-Open="_showTechnicianPanel">

        <div class="pa-6">

            <div class="d-flex justify-space-between align-center mb-4">

                <MudText Typo="Typo.h5" Color="Color.Dark">
                    Become a Technician
                </MudText>

                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Color="Color.Default"
                               OnClick="@(() => _showTechnicianPanel = false)" />

            </div>

            <MudText Typo="Typo.body2"
                     Color="Color.Secondary"
                     Class="mb-6">

                Fill in your professional details to start accepting service requests.

            </MudText>

            <MudTextField @bind-Value="_request.Skills"
                          Label="Skills"
                          Placeholder="AC Repair, Plumbing, Electrical..."
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mb-4"
                          Required="true" />

            <MudTextField @bind-Value="_request.Location"
                          Label="Location"
                          Placeholder="Palembang"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mb-4"
                          Required="true" />

            <MudTextField @bind-Value="_request.Bio"
                          Label="Short Bio"
                          Placeholder="Tell customers about your experience..."
                          Variant="Variant.Outlined"
                          Lines="4"
                          Margin="Margin.Dense"
                          Class="mb-6" />

            <MudButton FullWidth="true"
                       Size="Size.Large"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="_isSubmitting"
                       OnClick="SubmitBecomeTechnician">

                @if (_isSubmitting)
                {
                    <MudProgressCircular Indeterminate="true"
                                         Size="Size.Small"
                                         Class="mr-2" />
                }

                Submit Application

            </MudButton>

        </div>

    </MudDrawer>

    <!-- 📄 PAGE CONTENT -->
    <MudMainContent>

        <article class="content px-4">

            <AuthorizeView>
                <Authorized>
                    @Body
                </Authorized>

                <NotAuthorized>
                    <MudText Typo="Typo.h6">
                        Not authorized
                    </MudText>
                </NotAuthorized>
            </AuthorizeView>

        </article>

    </MudMainContent>

</MudLayout>

@code {

    private bool _drawerOpen = true;
    private bool _showTechnicianPanel;
    private bool _isSubmitting;
    private bool _isTechnician;
    private bool _initialized;

    private readonly CreateTechnicianProfileRequest _request = new();

    protected override void OnInitialized()
    {
        AppState.OnChange += Refresh;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized)
            return;

        _initialized = true;

        AppState.SetMode("customer");

        _isTechnician = await IsTechnician();

        await InvokeAsync(StateHasChanged);
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task HandleSwitch()
    {
        if (AppState.Mode == "technician")
        {
            AppState.SetMode("customer");

            NavigationManager.NavigateTo("/customer-tickets");

            return;
        }

        if (_isTechnician)
        {
            AppState.SetMode("technician");

            NavigationManager.NavigateTo("/available-tickets");
        }
        else
        {
            _showTechnicianPanel = true;
        }
    }

    private async Task SubmitBecomeTechnician()
    {
        try
        {
            _isSubmitting = true;

            var authState =
                await AuthStateProvider.GetAuthenticationStateAsync();

            var claim = authState.User
                .FindFirst(ClaimTypes.NameIdentifier);

            if (claim is null)
                return;

            await UserService.BecomeTechnician(
                int.Parse(claim.Value),
                _request);

            _isTechnician = true;

            _showTechnicianPanel = false;

            AppState.SetMode("technician");

            NavigationManager.NavigateTo("/available-tickets");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task<bool> IsTechnician()
    {
        var token = await LocalStorage.GetAsync<string>("token");

        if (!token.Success)
            return false;

        var request = new HttpRequestMessage(
            HttpMethod.Get,
            "/api/users/is-technician");

        request.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue(
                "Bearer",
                token.Value);

        var response = await Http.SendAsync(request);

        return response.IsSuccessStatusCode &&
               await response.Content.ReadFromJsonAsync<bool>();
    }

    public void Dispose()
    {
        AppState.OnChange -= Refresh;
    }
}