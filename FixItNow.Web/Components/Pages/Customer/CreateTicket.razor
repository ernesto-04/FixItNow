@page "/create-ticket"
@layout CustomerLayout

@using MudBlazor
@inject HttpClient Http
@inject ProtectedLocalStorage LocalStorage

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">

    <MudPaper Class="pa-6" Elevation="3">

        <MudText Typo="Typo.h5" GutterBottom="true">
            Create a Service Request
        </MudText>

        <!-- STEP PROGRESS -->
        <MudStepper @bind-ActiveIndex="step" Elevation="0">
            <MudStep Label="Category" />
            <MudStep Label="Photos" />
            <MudStep Label="Details" />
            <MudStep Label="Confirm" />
        </MudStepper>

        <MudDivider Class="my-4" />

        <!-- STEP 1: CATEGORY -->
        @if (step == 0)
        {
            <MudText Typo="Typo.subtitle1">What do you need help with?</MudText>

            <MudGrid Class="mt-2">
                @foreach (var cat in categories)
                {
                    <MudItem xs="6" sm="4">
                        <MudPaper Class="@GetCategoryClass(cat)"
                                  @onclick="() => ticket.Category = cat">
                            <MudText Align="Align.Center">@cat</MudText>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }

        <!-- STEP 2: PHOTOS -->
        @if (step == 1)
        {
            <MudText Typo="Typo.subtitle1">Upload photos (optional)</MudText>

            <label for="fileInput" style="width:100%">
                <MudPaper Class="pa-6 d-flex flex-column align-center justify-center upload-box">

                    <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Large" />

                    <MudText Typo="Typo.subtitle2">
                        Click to upload photos
                    </MudText>

                    <MudText Typo="Typo.caption">
                        Max 5 images • 10MB each
                    </MudText>

                </MudPaper>
            </label>

            <InputFile id="fileInput"
                       OnChange="HandleFileSelected"
                       multiple
                       hidden />

            <MudGrid Class="mt-3">
                @foreach (var img in imagePreviews.Select((value, index) => new { value, index }))
                {
                    <MudItem xs="4">
                        <MudPaper Class="pa-1 position-relative preview-box">

                            <MudImage Src="@img.value" Class="preview-img" />

                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           Class="remove-btn"
                                           OnClick="() => RemoveImage(img.index)" />

                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }

        <!-- STEP 3: DETAILS -->
        @if (step == 2)
        {
            <MudTextField Label="Title"
                          @bind-Value="ticket.Title"
                          Variant="Variant.Outlined"
                          FullWidth="true" />

            <MudTextField Label="Description"
                          @bind-Value="ticket.Description"
                          Lines="4"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Class="mt-3" />

            <MudTextField Label="Location"
                          @bind-Value="ticket.Location"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Class="mt-3" />
        }

        <!-- STEP 4: CONFIRM -->
        @if (step == 3)
        {
            <MudText Typo="Typo.subtitle1">Review your request</MudText>

            <MudList Dense="true" T="string">
                <MudListItem>Category: @ticket.Category</MudListItem>
                <MudListItem>Title: @ticket.Title</MudListItem>
                <MudListItem>Description: @ticket.Description</MudListItem>
                <MudListItem>Location: @ticket.Location</MudListItem>
            </MudList>
        }

        <!-- ACTION BUTTONS -->
        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">

            <MudButton Disabled="step == 0"
                       Variant="Variant.Text"
                       OnClick="PrevStep">
                Back
            </MudButton>

            @if (step < 3)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="NextStep">
                    Next
                </MudButton>
            }
            else
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           OnClick="Create">
                    Submit
                </MudButton>
            }
        </MudStack>

        <!-- RESULT -->
        @if (!string.IsNullOrEmpty(message))
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">
                @message
            </MudAlert>
        }

    </MudPaper>
</MudContainer>

@code {
    private int step = 0;

    private CreateTicketRequest ticket = new();
    private string message;

    private List<string> categories = new()
    {
        "Electrical",
        "Plumbing",
        "Cleaning",
        "AC Repair",
        "General"
    };

    private List<(byte[] Data, string Name, string ContentType)> files = new();
    private List<string> imagePreviews = new();

    private const int MaxFiles = 5;
    private const long MaxFileSize = 10 * 1024 * 1024; // 10MB

    private InputFile fileInput;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles(MaxFiles - files.Count))
        {
            if (files.Count >= MaxFiles)
                break;

            if (file.Size > MaxFileSize)
                continue;

            using var stream = file.OpenReadStream(MaxFileSize);
            using var ms = new MemoryStream();

            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            files.Add((bytes, file.Name, file.ContentType));

            var base64 = Convert.ToBase64String(bytes);
            imagePreviews.Add($"data:{file.ContentType};base64,{base64}");
        }
    }

    private string GetCategoryClass(string cat)
    {
        return ticket.Category == cat
            ? "pa-4 mud-elevation-8 rounded-lg text-center border border-primary"
            : "pa-4 mud-elevation-2 rounded-lg text-center";
    }

    private void NextStep() => step++;
    private void PrevStep() => step--;

    private async Task<string> GetToken()
    {
        var token = await LocalStorage.GetAsync<string>("token");
        return token.Success ? token.Value : null;
    }

    private void RemoveImage(int index)
    {
        if (index >= 0 && index < files.Count)
        {
            files.RemoveAt(index);
            imagePreviews.RemoveAt(index);
        }
    }

    private async Task Create()
    {
        var token = await GetToken();
        if (token == null) return;

        var request = new HttpRequestMessage(HttpMethod.Post, "https://localhost:7008/api/tickets/create-ticket");
        request.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var content = new MultipartFormDataContent();

        content.Add(new StringContent(ticket.Title ?? ""), "Title");
        content.Add(new StringContent(ticket.Description ?? ""), "Description");
        content.Add(new StringContent(ticket.Category ?? ""), "Category");
        content.Add(new StringContent(ticket.Location ?? ""), "Location");

        foreach (var file in files)
        {
            content.Add(
                new ByteArrayContent(file.Data),
                "Images",
                file.Name
            );
        }

        request.Content = content;

        var response = await Http.SendAsync(request);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<CreateTicketResponse>();
            message = $"Ticket #{result?.Id} created successfully!";
            ticket = new();
            step = 0;
            imagePreviews.Clear();
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            message = $"Failed: {error}";
        }
    }
}