<MudDialog>
    <DialogContent>

        <MudText Typo="Typo.h6" Class="mb-4">
            Become a Technician
        </MudText>

        <MudTextField @bind-Value="_request.Skills"
                      Label="Skills (e.g. AC Repair, Electrical)"
                      Required="true" />

        <MudTextField @bind-Value="_request.Location"
                      Label="Location"
                      Required="true" />

        <MudTextField @bind-Value="_request.Bio"
                      Label="Short Bio"
                      Lines="3" />

    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>

        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit">

            @if (_isLoading)
            {
                <MudProgressCircular Indeterminate="true" Size="Size.Small" />
            }
            else
            {
                <span>Submit</span>
            }

        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    @inject UserService _userService
    @inject AuthenticationStateProvider AuthStateProvider

    private CreateTechnicianProfileRequest _request = new();
    private bool _isLoading = false;

    async Task Submit()
    {

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            var userId = int.Parse(user.FindFirst(ClaimTypes.NameIdentifier).Value);
            _isLoading = true;

            _userService.BecomeTechnician(userId, _request);

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception e)
        {
            Console.WriteLine(e.Message);
        }
        finally
        {
            _isLoading = false;
        }
    }

    void Cancel() => MudDialog.Cancel();
}